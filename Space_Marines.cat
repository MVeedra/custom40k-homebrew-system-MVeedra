    <sharedRules>
        <rule name="They Shall Know No Fear" id="f2c8-35a6-1b2e-4be6" hidden="false">
            <description>A pinned or fleeing unit automatically regroups at the start of the turn or when it reaches the edge of the board. It can never use the "Take cover" Defensive reaction.</description>
        </rule>
    </sharedRules>
