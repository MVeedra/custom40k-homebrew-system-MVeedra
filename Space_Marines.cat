                <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">AT(1), Quick(+1), Can only be used with a Charge order</characteristic>
            </characteristics>
        </profile>
        <profile name="Power lance - Melee" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="4b30-c9ec-014a-4574">
            <characteristics>
                <characteristic name="Range" typeId="17a8-c6d1-4902-3240">-</characteristic>
