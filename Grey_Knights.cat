        </profile>
        <profile name="Warden of the Blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dc65-4a5d-60eb-416b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Increase the Ld of the model by 1. Additionally, it gains the "Cleansing flame" weapon. Unique. Only for Brotherhood-Champion.</characteristic>
            </characteristics>
