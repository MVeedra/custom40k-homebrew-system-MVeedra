                <characteristic name="Type" typeId="85b8-b86f-84a1-6a8a">Melee</characteristic>
                <characteristic name="S" typeId="dfe1-ab2e-bf82-b051">+6</characteristic>
                <characteristic name="AP" typeId="5769-5be9-c3dd-1b76">-3</characteristic>
                <characteristic name="D" typeId="40a0-b76f-918f-50a5">2</characteristic>
                <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">AT(2), Force weapon, Shield breaker(-1), Unique. Only for Captains.</characteristic>
            </characteristics>
        </profile>
        <profile name="Aquila Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b37e-5d3b-dad7-4608">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Augurium scrolls" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c664-b983-bdeb-432a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon gains "Life curse".</characteristic>
            </characteristics>
        </profile>
        <profile name="Bionics" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e785-c2c1-a8b4-43cc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 6+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Brotherhood banner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6134-4ca6-8135-4b5d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains a bonus of +1 to Leadership and Combat resolutions. As long as the banner bearer is alive, Mission objectives that are held by this unit can not be contested by enemy units. Additionally, all models in the unit gain +1 Attack. Only for Ancients.</characteristic>
            </characteristics>
        </profile>
        <profile name="Brotherhood initiate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fc4d-571a-b5b7-4cd1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may exchange one psychic power it knows with one from the list of "Brotherhood Powers". All Brotherhood Powers within an army must be the same, if any is chosen. Only for models from this Codex.</characteristic>
            </characteristics>
        </profile>
        <profile name="Deimos masterwork" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2082-ca3c-1bc0-4697">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One ranged weapon gains "Precision(5+)". Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Domina Liber Daemonica" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4257-b78e-735b-4364">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model re-rolls 1s for tests to manifest or deny psychic powers. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Familiar" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e3f5-4da2-1972-4117">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may sacrifice the Familiar to reroll a psychic power manifestation test. While it is alive, the model gains +1 Initiative. Only for Librarians.</characteristic>
            </characteristics>
        </profile>
        <profile name="First to the Fray" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f37f-4a22-3e33-4f93">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model must start the game in reserve and will arrive automatically in the first turn (together with its attached unit). They do not count towards the limit of how many units may enter from reserves each round. Must be the first activation of the player. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Grimoire of True Names" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9d5c-0b4d-edeb-4096">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One model in direct base contact suffers -1 penalties to its WS, Initiatives and Attacks, up to a minimum of 1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gyrotemporal vault" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="756f-5465-b540-4d41">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the model successfully manifested a psychic power during its activation, it gains +1 Initiative unti the beginning of its next activation. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hexagram warding runes" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cd6c-9c97-a9de-4fca">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models in direct base contact suffer a -1 penalty to their invulnerability saves.</characteristic>
            </characteristics>
        </profile>
        <profile name="Inescapable Wrath" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="393f-c9d5-5b33-4aab">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain "Frenzy(2")". Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Iron halo" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1c13-4057-9856-4518">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Librum Arcana" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3625-e955-957d-48f3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows all psychic power from any discipline it would normally have access to. Unique. Only for Librarians. </characteristic>
            </characteristics>
        </profile>
        <profile name="Mandulian Reliquary" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9b16-f8af-8678-40dc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain the "Objective secured!" ability. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 to its Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="07d5-ce8f-42ff-4940">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Personal teleporter" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d169-c1f9-a078-4ff2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement and the "Jump pack" and "Shunt" abilities (See Interceptor Squad). Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Protection balm" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c42-b69c-fee5-4e33">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains "Aegis(4+)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Psy-ammunition" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="eba6-93e6-6915-41ce">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All ranged weapon of the model gain +1 Strength. Only works on weapons with Strength 4 or below.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity Seals" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="82c3-5e57-f077-4ca6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy psykers suffer a -1 to manifestation rolls if they target the model or its attached unit directly.</characteristic>
            </characteristics>
        </profile>
        <profile name="Relic helm" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bed0-0a0c-a7af-4d0d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can manifest and deny an additional psychic power per turn. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Sacred weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f285-5639-6696-4fa4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Each improvement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Selfless healer" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc7e-09a2-6bb6-4fc2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the end of its movement, the model can attempt to heal a creature within 3". On a 4+, a model regains up to 1 lost Wound. Only for Apothecaries. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Soul imprint" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="702b-1aff-db13-424f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon gains "Shred". Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Radiant Champion" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5afa-1816-b268-498c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All melee weapons of the model gain "Soul burn(5+)". Unique. Only for Brotherhood-Champion.</characteristic>
            </characteristics>
        </profile>
        <profile name="Storm shield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cc5e-9bdb-c532-4a26">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the abilities "Deflect" and "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 to its Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep Strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Emperors Tarot" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f386-e4cb-36f0-4002">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, the own Initiative roll may be re-rolled. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Strands of Fate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8f74-a89a-1442-4d41">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll any one die per activation. Unique.</characteristic>
            </characteristics>
        </profile>
