            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bladevanes" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="5c24-fc1b-cde4-4cc4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Vector strike" ability and the following weapon: S:+1 AP:-2 D:1, Unwieldy.</characteristic>
            </characteristics>
        </profile>
        <profile name="Flickerfield" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3246-b588-e0a7-433c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Improved targeting" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="34d4-53c0-250c-47a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Night shield" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="a902-b891-c434-4245">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy model reduce their weapons range by 12", if they target the bearer.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit. The order is consumed by doing so.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="103b-cecb-aadb-4233">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units within a 6" radius suffer -1 to their Leadership.</characteristic>
            </characteristics>
        </profile>
