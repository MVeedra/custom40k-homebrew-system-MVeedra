    <sharedRules>
        <rule name="Combat drugs" id="5729-bfba-1009-49df" hidden="false">
            <description>After all units have been set up, you may pick a combat drug for the unit. Its effect last for the remaining battle.</description>
        </rule>
        <rule name="Power through Pain" id="2e8e-f280-b841-4c9a" hidden="false">
            <description>Each time an enemy unit is destroyed, the army gains a "Power Through Pain" token, which is assigned a special rule from the list. Then distribute the token to any friendly unit with the "Power Through Pain" special rule. All models in a unit benefit from the bonus, but multiple markers with the same bonus don't stack.
Aegis(4+)
Berserk(4+)
Furious Charge
+1 Inititive
+1 Leadership
+1 Strength
Character models that join a unit pool their "Power through Pain" token together. Once they leave the unit, these tokens have to be split up evenly.</description>
        </rule>
        <rule name="Webway raid" id="23dc-85a0-367b-4a6f" hidden="false">
            <description>For each started 1000 points of game size, one infantry unit (including attached character models) may be set up using the rules for Infiltrators for +1 point per wound.</description>
        </rule>
        <rule name="Deception" id="0af1-e30c-b986-4f67" hidden="false">
            <description>After all units have been placed in the Deployment phase, the Dracon may remove and redeploy one of his units.</description>
        </rule>
        <rule name="Archon" id="49cd-cb88-58c1-449e" hidden="false">
            <description>Another unit may be redeployed.</description>
        </rule>
        <rule name="Master Haemonculus" id="8c52-b282-f3a6-424a" hidden="false">
            <description>A Master Haemonculus starts with an additional "Power through Pain" token.</description>
        </rule>
        <rule name="Transformed shape" id="c531-ef46-5db5-4a57" hidden="false">
            <description>The unit starts with a "Power through Pain" token.</description>
        </rule>
        <rule name="Master Succubus" id="0a45-c23d-7457-4358" hidden="false">
            <description>The model may select a second Combat drug.</description>
        </rule>
        <rule name="Aspect armor" id="183d-7ca3-a557-473b" hidden="false">
            <description>The model gains a 5+ invulnerability save.</description>
        </rule>
        <rule name="Swords for hire" id="e483-0f36-16f9-496f" hidden="false">
            <description>Add the <Kabal>, <Coven> or <Cult> keyword to the unit.</description>
        </rule>
        <rule name="Hunter" id="c3e8-3403-d549-4d6b" hidden="false">
            <description>The unit rerolls hit and wound rolls against HQ and character models.</description>
        </rule>
        <rule name="Fade away" id="0a27-e3e4-6ce0-4c61" hidden="false">
            <description>During each Reinforcement phase, the unit may be set up again following the rules for Infiltrator.</description>
        </rule>
        <rule name="Shadow Creature" id="5f28-8af4-4e37-49ac" hidden="false">
            <description>The unit has a 5+ invulnerability saving throw. Hit rolls against the unit suffer a –1 penalty.</description>
        </rule>
        <rule name="Ghostplate armor" id="f741-975f-c7fa-4fa4" hidden="false">
            <description>The unit got a 5+ invulnerability save.</description>
        </rule>
        <rule name="Soul harvest" id="2f3b-d88b-8992-405b" hidden="false">
            <description>After each activation in which the Cronos eliminates an enemy model, a friendly Dark Eldar unit within 18" gains a Power Through Pain token.</description>
        </rule>
        <rule name="Aerial assault" id="b2be-b94e-0316-4474" hidden="false">
            <description>The unit may fire all ranged weapons if it moved up to 12".</description>
        </rule>
        <rule name="Talos ichor injector" id="f5f1-d000-27c6-4346" hidden="false">
            <description>For each successful hit roll with this weapon, the target must pass a Toughness test. If the test fails, the model dies immediately. Doesn't work against vehicles.</description>
        </rule>
        <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
            <description>This model has a transport capacity of 6 infantry models.</description>
        </rule>
        <rule name="Vector Strike" id="6e1c-9cd6-ef10-4429" hidden="false">
            <description>Any unit this model overflows takes an automatic hit with its melee weapon profile.</description>
        </rule>
    </sharedRules>
