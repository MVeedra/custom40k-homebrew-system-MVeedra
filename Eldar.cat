                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Champion of Ynnead" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b329-429c-e1e8-4da2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Everytime a model dies within 6" of this model it gains one temporary wound. The wound is lost at the end of the battle round. Can only have one temporary wound at a time.</characteristic>
            </characteristics>
        </profile>
        <profile name="Crystal body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1a0a-b32f-6a35-43be">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Eldar jetbike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6e46-95e0-bdec-4cfd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Toughness, +1 Wound, a twin shuriken catapult and the ability "Jet bike". Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Faolchu's wings" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6382-7c9e-4503-4a17">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement and the ability "Jump pack infantry". Additionally, it gains the "Sky Dive" ability (see Swooping Hawks). Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Fire blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f5b9-0a1b-1c18-493b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains Precision(5+) and cumulative -2 AP. Unique. Can't be combined with other blades.</characteristic>
            </characteristics>
        </profile>
        <profile name="Forcefield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3e99-197a-f534-4d08">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ghosthelm" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c789-58cd-5273-4168">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first Perils of the warp attack of the game.</characteristic>
            </characteristics>
        </profile>
        <profile name="Heavy armor plating" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ab09-fd8a-8e7e-4da0">
