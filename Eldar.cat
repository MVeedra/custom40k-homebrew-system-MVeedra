        <characteristic name="Cast value" typeId="931b-9d36-5e7f-f4df">7</characteristic>
        <characteristic name="Effect" typeId="f342-212f-7d7a-d01c">If the target unit consists of creatures, it suffers 1D6 automatic wounds with S: 10 DS: -3 D: 1; Seeking. Vehicles suffer 1D3 penetrating hits; AT(2), Seeking.</characteristic>
        <characteristic name="Duration" typeId="6dd7-21f2-42b3-4e1d">Instant</characteristic>
        <characteristic name="Complexity" typeId="8ee5-1aad-da49-39b2">Normal</characteristic>
      </characteristics>
    </profile>
    <profile name="Word of the Phoenix" typeId="be7d-d5d5-f5cf-be4f" typeName="Psychic Powers" hidden="false" id="36ce-9e1b-27e5-9874">
      <characteristics>
        <characteristic name="Type" typeId="e004-51ac-9b24-2946">Augmentation</characteristic>
        <characteristic name="Range" typeId="ec7e-be8e-1543-3942">24&quot;</characteristic>
        <characteristic name="Target" typeId="4d02-1799-54fd-bbff">Friendly unit</characteristic>
        <characteristic name="Cast value" typeId="931b-9d36-5e7f-f4df">7</characteristic>
        <characteristic name="Effect" typeId="f342-212f-7d7a-d01c">The model may heal a friendly Eldar unit (excluding itself and &lt;Wraith&gt; units) within range for 3 wounds. Dead models may be revived with this ability. Injured models have to be fully healed first. Can only be successfully manifested once per round and per psyker.</characteristic>
        <characteristic name="Duration" typeId="6dd7-21f2-42b3-4e1d">Instant</characteristic>
        <characteristic name="Complexity" typeId="8ee5-1aad-da49-39b2">Complex</characteristic>
      </characteristics>
    </profile>
    <profile name="Enliven" typeId="be7d-d5d5-f5cf-be4f" typeName="Psychic Powers" hidden="false" id="8857-f4a4-392c-906b">
      <characteristics>
        <characteristic name="Type" typeId="e004-51ac-9b24-2946">Augmentation</characteristic>
        <characteristic name="Range" typeId="ec7e-be8e-1543-3942">24&quot;</characteristic>
        <characteristic name="Target" typeId="4d02-1799-54fd-bbff">Friendly &lt;Wraith&gt; unit</characteristic>
        <characteristic name="Cast value" typeId="931b-9d36-5e7f-f4df">4</characteristic>
        <characteristic name="Effect" typeId="f342-212f-7d7a-d01c">The target gains the &quot;Battle Focus&quot; ability and +1 Initiative.</characteristic>
        <characteristic name="Duration" typeId="6dd7-21f2-42b3-4e1d">Until the caster&apos;s next activation</characteristic>
        <characteristic name="Complexity" typeId="8ee5-1aad-da49-39b2">Basic</characteristic>
      </characteristics>
    </profile>
    <profile name="Deliverance" typeId="be7d-d5d5-f5cf-be4f" typeName="Psychic Powers" hidden="false" id="ad16-ee4c-e96e-4526">
      <characteristics>
        <characteristic name="Type" typeId="e004-51ac-9b24-2946">Augmentation</characteristic>
        <characteristic name="Range" typeId="ec7e-be8e-1543-3942">24&quot;</characteristic>
        <characteristic name="Target" typeId="4d02-1799-54fd-bbff">Friendly &lt;Wraith&gt; unit</characteristic>
        <characteristic name="Cast value" typeId="931b-9d36-5e7f-f4df">5</characteristic>
        <characteristic name="Effect" typeId="f342-212f-7d7a-d01c">The target unit regains 1 lost wound. Dead models may be revived with this. Living models have to be healed completly first.</characteristic>
        <characteristic name="Duration" typeId="6dd7-21f2-42b3-4e1d">Until the caster&apos;s next activation</characteristic>
        <characteristic name="Complexity" typeId="8ee5-1aad-da49-39b2">Basic</characteristic>
      </characteristics>
    </profile>
