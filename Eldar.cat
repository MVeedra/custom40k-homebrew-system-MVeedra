    <profile name="Champion of Ynnead" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b329-429c-e1e8-4da2">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Everytime a model dies within 6&quot; of this model it gains one temporary wound. The wound is lost at the end of the battle round. Can only have one temporary wound at a time.</characteristic>
      </characteristics>
    </profile>
    <profile name="Crystal body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1a0a-b32f-6a35-43be">
