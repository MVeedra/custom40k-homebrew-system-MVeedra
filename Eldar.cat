        <characteristic name="Cast value" typeId="931b-9d36-5e7f-f4df">6</characteristic>
        <characteristic name="Effect" typeId="f342-212f-7d7a-d01c">The target suffers one automatic hit with S:5 AP:-1 D:1, Barrage, Seeking, Suppression.</characteristic>
