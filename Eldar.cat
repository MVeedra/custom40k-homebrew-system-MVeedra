            </characteristics>
        </profile>
        <profile name="Hungering blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3196-40d4-35e3-4816">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains cumulative Flurry(4). Unique. Can't be combined with other blades.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mandiblaster" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6cb3-32dd-dd54-4cde">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During the model's initiave step, roll a D6. On a 4+, one enemy unit in melee suffers an automatic wound with S:4 AP:-2 D:1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mirrorgaze" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3dbf-dbb4-cc95-420a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Deflect" and "Parry" abilities. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Paragon of fate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e608-3c1b-de37-459f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, Wounds and Attacks. The model and its attached unit may re-roll any single die per activation. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Paragon of war" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e7a3-9d86-da00-49da">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Strength, Toughness, Wounds and Attacks. It can chose a single Exarch power. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Phoenix gem" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="58d7-cab9-dd15-4dad">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll a die the first time the model is eliminated: 
1,2 - Remove the model.
3,4 - Set it back up with 1 wound. 
5,6 - Set it up again with 2 wounds. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic mastery" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9724-d530-408e-4502">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The models gains +1 to all tests for manifesting a psychic power.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Rune armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3f1a-c689-61d9-4a8f">
            <characteristics>
