    <profile name="Masters of Concealment" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="4db6-7f4e-e25c-7788">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the benefit of light cover until its first activation.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mobile Fighters" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="1b25-dad2-072d-7d8b">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit disembarked from a transport this round, all of its weapons gain the &quot;Decimate&quot; ability for this activation.</characteristic>
      </characteristics>
    </profile>
    <profile name="Savage Blades" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="e23f-446b-dcbf-1d20">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, all of its melee weapons gain -1 AP for this activation.</characteristic>
      </characteristics>
    </profile>
    <profile name="Students of Vaul" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="23a5-4b85-2e62-7b3a">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit ignores temporary vehicle damage on a roll of 4+.</characteristic>
      </characteristics>
    </profile>
    <profile name="Masterful Shots" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="fecf-567d-ec5c-489f">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the &quot;Sunder(1)&quot; ability for all ranged attacks.</characteristic>
      </characteristics>
    </profile>
    <profile name="Shimmershield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b4cd-d726-9d7d-6621">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain a 4+ invulnerability save in melee.</characteristic>
      </characteristics>
    </profile>
    <profile name="Forceshield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7834-f296-8f0b-e0e5">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the &quot;Deflect&quot; and &quot;Parry&quot; abilities.</characteristic>
      </characteristics>
    </profile>
    <profile name="Gloom field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9c38-fd4b-67c2-70c7">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units that are at least 12&quot; away from the unit reduce their weapon range by 6&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Wireweave net" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="12fd-feeb-0291-c919">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, after this unit used Defensive fire, the attacker suffers 1D6+1 automatic wounds and reduces their charging range by 2&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mistshield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b797-4f65-5c2d-488c">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and it&apos;s attached unit gain a 5+ invulnerability save against ranged attacks.</characteristic>
      </characteristics>
    </profile>
    <profile name="Serpent shield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0ae5-3cbc-fb1b-af61">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit have a 5+ invulnerability save against ranged attacks. If the unit got 2 Serpent scale platforms, the invulnerability save is improved to 4+.</characteristic>
      </characteristics>
    </profile>
    <profile name="Channeler stones" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3a55-3647-6822-9d4d">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per turn, the damage of a wound against the model or attached unit can be reduced by 1. The ability must be declared after armor and invulnerability saves. Does not work against weapons with a strength of 8 or above.</characteristic>
      </characteristics>
    </profile>
    <profile name="Faolchu" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0f1a-b84b-0e91-c3ca">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All weapons of the unit gain +1 AP when shooting at targets that benefit from cover.</characteristic>
      </characteristics>
    </profile>
    <profile name="Destructor" typeId="be7d-d5d5-f5cf-be4f" typeName="Psychic Powers" hidden="false" id="2297-85d9-72c3-6d22">
