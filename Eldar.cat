        <categoryLink name="Flyer" hidden="false" id="763b-3d5e-d324-4f30" targetId="72bc-3f6f-145a-3688" primary="true"/>
      </categoryLinks>
    </entryLink>
    <entryLink import="true" name="Spiritseer" hidden="false" id="b672-06fe-e3ec-05a1" type="selectionEntry" targetId="6e53-46c1-f3ad-1507"/>
    <entryLink import="true" name="Warlocks" hidden="false" id="9956-eaaa-90e1-7d0b" type="selectionEntry" targetId="7dd9-fef3-2fb8-c4d4"/>
    <entryLink import="true" name="Wraithblades" hidden="false" id="16f6-822c-523f-8f41" type="selectionEntry" targetId="6b5e-d538-67f3-bde5"/>
    <entryLink import="true" name="Wraithguard" hidden="false" id="d38e-ca31-8cc3-89f9" type="selectionEntry" targetId="cb9e-e2b0-219a-ce3d"/>
    <entryLink import="true" name="Windriders" hidden="false" id="3991-63d3-cf47-4d75" type="selectionEntry" targetId="6206-f09c-67b6-6d3f"/>
    <entryLink import="true" name="Rangers" hidden="false" id="8609-d070-26c9-432a" type="selectionEntry" targetId="3fe4-fb1d-a931-9832"/>
    <entryLink import="true" name="Voidreavers" hidden="false" id="1dc0-7b36-f000-de22" type="selectionEntry" targetId="7471-0a05-dbfc-460e"/>
    <entryLink import="true" name="Guardian Defenders" hidden="false" id="2785-b0da-4235-1f97" type="selectionEntry" targetId="c9d9-b724-d52a-0291"/>
    <entryLink import="true" name="Storm Guardians" hidden="false" id="7312-0546-6889-af0a" type="selectionEntry" targetId="fdbd-7c15-a7ae-1171"/>
    <entryLink import="true" name="Dark Reapers" hidden="false" id="9a4a-10ee-0fce-6131" type="selectionEntry" targetId="82aa-16df-fc0d-a25c"/>
    <entryLink import="true" name="Dire Avengers" hidden="false" id="c9d6-9369-b4a1-a403" type="selectionEntry" targetId="12fc-858a-1f1c-f17b"/>
    <entryLink import="true" name="Fire Dragons" hidden="false" id="db1a-035f-4ad1-a48f" type="selectionEntry" targetId="099d-09a8-4f10-b889"/>
    <entryLink import="true" name="Howling Banshees" hidden="false" id="0aaf-dab9-aaf3-3918" type="selectionEntry" targetId="0b02-3210-26a8-b01c"/>
    <entryLink import="true" name="Shining Spears" hidden="false" id="d3ff-63ff-095d-4e47" type="selectionEntry" targetId="28da-072e-2cbe-78e5"/>
    <entryLink import="true" name="Striking Scorpions" hidden="false" id="218a-3686-fbcf-471a" type="selectionEntry" targetId="460c-0c77-3e66-edc6"/>
    <entryLink import="true" name="Swooping Hawks" hidden="false" id="cd8c-0584-4b13-896d" type="selectionEntry" targetId="2b58-adc0-9744-934f"/>
    <entryLink import="true" name="Warp Spiders" hidden="false" id="e9ef-2300-d11f-52c1" type="selectionEntry" targetId="8423-58ee-b080-bcaa"/>
    <entryLink import="true" name="Vindicare Assassin" hidden="false" id="6e68-4058-2543-62f9" type="selectionEntry" targetId="3016-b48e-50d0-8582"/>
    <entryLink import="true" name="Legacies" hidden="false" id="be9d-3303-5250-4051" type="selectionEntry" targetId="db2b-5a42-6474-2cb0"/>
    <entryLink import="true" name="Wasps" hidden="false" id="6279-189b-9abc-fc86" type="selectionEntry" targetId="5bc7-275f-b589-37b8"/>
    <entryLink import="true" name="Wasps" hidden="false" id="955a-8546-ead7-1f57" type="selectionEntry" targetId="0f4c-6a58-3f73-4c81"/>
    <entryLink import="true" name="Wraithseer" hidden="false" id="042a-4c99-263c-d046" type="selectionEntry" targetId="bbb8-74f3-a674-249d"/>
    <entryLink import="true" name="Shadow Spectres" hidden="false" id="e5a8-9596-4c46-6859" type="selectionEntry" targetId="1217-8ae9-025e-f2d7"/>
    <entryLink import="true" name="Shadow Spectres" hidden="false" id="88f3-758d-7880-41c2" type="selectionEntry" targetId="ba05-4086-2365-1d35"/>
    <entryLink import="true" name="Hornets" hidden="false" id="4e1b-83cf-665f-2dff" type="selectionEntry" targetId="bcae-d888-81cd-689e"/>
    <entryLink import="true" name="Nightwing" hidden="false" id="f483-122a-5110-ed84" type="selectionEntry" targetId="b547-d340-ba46-7958"/>
    <entryLink import="true" name="Phoenix" hidden="false" id="4145-95fe-a210-259b" type="selectionEntry" targetId="1383-6b7d-98c6-6958"/>
  </entryLinks>
  <sharedRules>
    <rule name="Battle Focus" id="6bf6-be1d-576f-4aa9" hidden="false">
      <description>&quot;Assault&quot;, &quot;Grenade&quot; and &quot;Pistol&quot; type weapons ignore the to hit penalty for &quot;Advance&quot; and &quot;Charge&quot; orders. &quot;Heavy&quot; weapons can be used without penalty with a &quot;Move &amp; Shoot&quot; order and with a -1 to hit penalty with &quot;Advance&quot; and &quot;Charge&quot; orders. All psychic powers are treated as &quot;Basic&quot;.</description>
    </rule>
    <rule name="Shuriken" id="5fea-acb8-d34d-49ae" hidden="false">
      <description>To wound rolls of 5+ gain additional -2 AP.</description>
    </rule>
    <rule name="Webway strike" id="3df8-43e6-602c-46e8" hidden="false">
      <description>For each started 1000 points of game size, one infantry unit (including attached character models) may be set up using the rules for Infiltrators for +1 point per Wound.</description>
    </rule>
    <rule name="Perfected warfare" id="6626-0fcd-43e5-437a" hidden="false">
      <description>An Autarch can decide once per game to get a +1/-1 modifier to rolls during the Reinforcement phase and/or a +1/-1 modifier during the Initiative phase. The ability may be used after rolls have been made by both players.</description>
    </rule>
    <rule name="Exalted Autarch" id="f76e-fc97-f291-48a9" hidden="false">
      <description>The Autarch may use Perfected warfare twice per game.</description>
    </rule>
    <rule name="Molten body" id="942a-4752-45ec-4f55" hidden="false">
      <description>Enemy attacks reduce their AP value by -2 (to a minimum of 0) and damage by 1 (to a minimum of 1). If the model loses its last Wound, it explodes like a vehicle.</description>
    </rule>
    <rule name="Psyker" id="943c-18af-a1bb-44ed" hidden="false">
      <description>The model can cast 1 power and deny 1 power per battle round. It knows Smite and two powers from a chosen discipline.</description>
    </rule>
    <rule name="Exalted Farseer" id="0c37-9c58-a642-4a84" hidden="false">
      <description>The model can cast and deny 1 additional power per battle round.</description>
    </rule>
    <rule name="Inevitable death" id="a94e-0c25-14de-4083" hidden="false">
      <description>Once per game, after a friendly unit is removed, the Yncarne can be set up immediately to that position. Set the Yncarne up within 6&quot; of the last removed model. You have to keep at least 1&quot; away from enemy units. This way of moving does not count as an activation and can not be used while being in an ongoing melee combat.</description>
    </rule>
    <rule name="Crewed platform" id="67d6-06cb-007d-49b6" hidden="false">
      <description>If the last Guardian Defender is removed, all remaining Serpent scale platforms are destroyed. They are ignored for all kinds of unit strength and moral purposes.</description>
    </rule>
    <rule name="Gloom field" id="74f1-7eb8-9456-4c09" hidden="false">
      <description>Enemy units that are at least 12&quot; away from the unit reduce their weapon range by 6&quot;.</description>
    </rule>
    <rule name="Pathfinder ambush" id="d07f-42d3-3bad-4fa5" hidden="false">
      <description>Once an enemy unit emerges from reserve, a Ranger unit in reserve may perform an intercept. The unit is immediately deployed within 18&quot; but at least 9&quot; of the enemy reserve unit. The Rangers can then fire at that unit as if they had been given the &quot;Stand &amp; Shoot&quot; order. The attack resolves after the enemy unit has been deployed and before it takes another action.</description>
    </rule>
    <rule name="Wireweave net" id="9fe5-1f04-f1fc-42fa" hidden="false">
      <description>Once per game, after this unit used Defensive fire, the attacker suffers 1D6+1 automatic wounds and reduces their charging range by 2&quot;.</description>
    </rule>
    <rule name="Serpent shield" id="44fb-911a-6552-46d2" hidden="false">
      <description>The model and its attached unit have a 5+ invulnerability save against ranged attacks. If the unit got 2 Serpent scale platforms, the invulnerability save is improved to 4+.</description>
    </rule>
    <rule name="Mistshield" id="972a-7e2e-434f-4ef3" hidden="false">
      <description>The model and it&apos;s attached unit gain a 5+ invulnerability save against ranged attacks.</description>
    </rule>
    <rule name="Neuro disruptor" id="8fd0-e940-27ac-407b" hidden="false">
      <description>Roll 3D6 after a successful hit and compare it with the Leadership value of the unit. If your roll is higher, the target suffers an automatic wound with no saves allowed.</description>
    </rule>
    <rule name="Outcasts and Pirates" id="cf90-8288-0cdf-4c59" hidden="false">
      <description>This unit can&apos;t be a mandatory Troop selection.</description>
    </rule>
    <rule name="Aspect armor" id="183d-7ca3-a557-473b" hidden="false">
      <description>The model gains a 5+ invulnerability save.</description>
    </rule>
    <rule name="Shimmershield" id="241a-9c8d-a0fa-4c16" hidden="false">
      <description>The model and its attached unit gain a 4+ invulnerability save in melee.</description>
    </rule>
    <rule name="Mandiblaster" id="1a0c-6cf2-c67d-4933" hidden="false">
      <description>During the model&apos;s initiave step, roll a D6. On a 4+, one enemy unit in melee suffers an automatic wound with S4 AP-2 D1.</description>
    </rule>
    <rule name="Channeler stones" id="dadd-9cda-9e18-4baa" hidden="false">
      <description>Once per turn, the damage of a wound against the model or attached unit can be reduced by 1. The ability must be declared after armor and invulnerability saves. Does not work against weapons with a strength of 8 or above.</description>
    </rule>
    <rule name="Faolch�" id="6772-d9d6-160c-4637" hidden="false">
      <description>All weapons of the unit gain +1 AP when shooting at targets that benefit from cover.</description>
    </rule>
    <rule name="Ghosthelm" id="ea34-cc39-8a40-489b" hidden="false">
      <description>The Way Seeker ignores the first Perils of the warp attack each round.</description>
    </rule>
    <rule name="Shade Runner Assault" id="c5a7-7623-52cf-4d73" hidden="false">
      <description>After finishing a charge move, the enemy unit suffers one automatic wound with S4 AP0 D1 for every friendly model that made it into base contact.</description>
    </rule>
    <rule name="Sniper" id="34f3-b13b-c76e-4a7e" hidden="false">
      <description>A model equipped with a Ranger long rifle increases their BS by +1.</description>
    </rule>
    <rule name="Seer council" id="eda4-c856-189f-476d" hidden="false">
      <description>A Farseer gets a cumulative +1 bonus to casting and denying psychic powers for each Warlock in their unit. Accompanying Warlocks receive the same bonus for each Warlock after the first.</description>
    </rule>
    <rule name="Forceshield" id="0d5e-1331-745b-4d5f" hidden="false">
      <description>The model gains the &quot;Deflect&quot; and &quot;Parry&quot; abilities.</description>
    </rule>
    <rule name="Wraithbone" id="aaf6-1f11-4b5a-4bd8" hidden="false">
      <description>Reduces AP of enemy attacks by -1 (to a minimum of 0).</description>
    </rule>
    <rule name="Distortion" id="3c54-ea9a-213f-4759" hidden="false">
      <description>The weapon has a -1 penalty for to wound rolls.</description>
    </rule>
    <rule name="Strength &quot;D&quot;" id="5cf0-3f9c-712e-4fa5" hidden="false">
      <description>A to wound roll of 2+ always wounds a creature or penetrates a vehicle.</description>
    </rule>
    <rule name="Sky Dive" id="ec03-77c2-80d7-4330" hidden="false">
      <description>Once per game, at the start of their activation, the unit may use a Stand &amp; Shoot order to be immediately re-deployed anywhere on the battlefield. They must keep a minimum distance of 6&quot; to enemy models.</description>
    </rule>
    <rule name="Monofilament" id="2ef5-cbe9-5de7-4e92" hidden="false">
      <description>If the target enemy unit is in cover and at least one hit has been scored with the weapon, the terrain counts as difficult and dangerous terrain until the end of the next activation of the target unit.</description>
    </rule>
    <rule name="Shunting" id="11a6-c9ad-ed88-4c89" hidden="false">
      <description>The unit rolls and moves an additional 1D6 when using the Advance order. If a double 1 is rolled, the unit suffers an automatic wound with no save allowed.</description>
    </rule>
    <rule name="Cloudstrike" id="ca19-183b-69f1-4afc" hidden="false">
      <description>The model scatters only 1D6&quot; when being deployed via Deep strike.</description>
    </rule>
    <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
      <description>This model has a transport capacity of 12 infantry models.</description>
    </rule>
    <rule name="Support Weapons crew" id="ed8d-141a-3052-4527" hidden="false">
      <description>Every instance of damage can only ever cause 1 wound loss. Attacks with the &quot;Barrage&quot; or &quot;Explosive&quot; ability cause one hit for each Wound remaining on the model.</description>
    </rule>
    <rule name="Vibro" id="c70e-8220-b63d-491b" hidden="false">
      <description>If more than one Vibro cannon is shooting at the same target, the weapon gets the &quot;Decimate&quot; ability.</description>
    </rule>
    <rule name="Power field" id="47d2-6669-d957-49e4" hidden="false">
      <description>The model gains a 5+ invulnerability save.</description>
    </rule>
    <rule name="Wave Serpent Shield" id="7370-6667-3925-4eab" hidden="false">
      <description>The model has a 5+ invulnerability save.</description>
    </rule>
    <rule name="Vector dancer" id="7abb-d1de-7291-488c" hidden="false">
      <description>The model gains a 4+ invulnerability save.</description>
    </rule>
    <rule name="&lt;Aspect&gt;" id="4d25-3157-abee-df32" hidden="false"/>
    <rule name="&lt;Corsairs&gt;" id="7962-e323-4e43-badd" hidden="false"/>
    <rule name="&lt;Wraith&gt;" id="f422-4728-75c7-2c07" hidden="false"/>
    <rule name="&lt;Ynnari&gt;" id="a3b4-9ed4-8254-d7fd" hidden="false"/>
    <rule name="Bladestorm" id="eaab-493d-d022-53fa" hidden="false">
      <description>The model and its unit trigger the &quot;Shuriken&quot; special rule on each to wound roll.</description>
    </rule>
    <rule name="Burning heat" id="8201-5e60-1086-085a" hidden="false">
      <description>Ranged weapons of the model gain an additional -1 AP against units in cover.</description>
    </rule>
    <rule name="Crack shot" id="f2a1-67f4-ea9c-72af" hidden="false">
      <description>One ranged weapon of the model gets the &quot;Seeking&quot; ability each round.</description>
    </rule>
    <rule name="Crushing blows" id="c1b8-6628-a38f-71e9" hidden="false">
      <description>The model may re-roll one to wound or armor penetration roll in melee.</description>
    </rule>
    <rule name="Defensive stance" id="d17c-450b-d6c1-b2ef" hidden="false">
      <description>The model may use Defensive fire twice when getting charged.</description>
    </rule>
    <rule name="Dragon&apos;s bite" id="6c80-f47d-34fc-61d7" hidden="false">
      <description>Ranged weapons of the model gain a cumulative AT(1).</description>
    </rule>
    <rule name="Graceful avoidance" id="5c36-be10-90ed-2245" hidden="false">
      <description>The model and its unit got a 4+ invulnerability save against melee attacks.</description>
    </rule>
    <rule name="Heartstrike" id="1bcd-e920-b8ea-4597" hidden="false">
      <description>Melee attacks of the model gain Deadly(5+). If the model already has the rule, increase Deadly(x+) by 1. For example Deadly(5+) becomes Deadly(4+).</description>
    </rule>
    <rule name="Lightning attacks" id="dcdd-5aed-9824-b84b" hidden="false">
      <description>The model and its unit may consolidate 6&quot; after winning a melee combat. If it consolidates into an enemy unit, that unit may not use Defensive Fire.</description>
    </rule>
    <rule name="Piercing strike" id="afb3-97f7-55c1-e9c6" hidden="false">
      <description>Melee attacks of the model gain Armor piercing(5+).</description>
    </rule>
    <rule name="Rapid redeployment" id="d3d5-ffc6-0b26-d71b" hidden="false">
      <description>The model and its unit gain the &quot;Hit &amp; Run&quot; ability.</description>
    </rule>
    <rule name="Reaper&apos;s reach" id="38fe-86f1-13e1-1b19" hidden="false">
      <description>Ranged weapons of the model and its attached unit gain +6&quot; range.</description>
    </rule>
    <rule name="Scorpion&apos;s sting" id="754a-c07b-782b-8f35" hidden="false">
      <description>Melee attacks of the model gain Precision(5+).</description>
    </rule>
    <rule name="Skyhunter" id="9c45-f77b-b418-fe38" hidden="false">
      <description>All ranged weapons of the model gain Anti-Air.</description>
    </rule>
    <rule name="Stand firm" id="d083-80d8-a65b-d384" hidden="false">
      <description>The model and its unit gain the &quot;Objective secured!&quot; ability.</description>
    </rule>
    <rule name="Surprise assault" id="3354-f9fb-98df-6a7f" hidden="false">
      <description>If the model used the &quot;Shunting&quot; ability this round, it may shoot one additional time with each equipped Death spinner. If the model used the &quot;Sky dive&quot; ability this round, it doubles their shots with a Hawk&apos;s talon or Lasblaster.</description>
    </rule>
    <rule name="Lightning Reflexes" id="489b-9153-9b01-c26b" hidden="false" publicationId="f731-6aa6-pubN66377">
      <description>A model with this special rule has a 4+ invulnerable save.</description>
    </rule>
    <rule name="Lone Operative" id="6511-e478-b562-6dfb" hidden="false">
      <description>An army may only have one Assassin.</description>
    </rule>
    <rule name="Jump Jet" id="99ec-0562-7382-ef3b" hidden="false">
      <description>When this model executes an Advance or Charge order, it gets +6&quot; to its movement and the Anti-Grav rule.</description>
    </rule>
    <rule name="Ghostlight" id="09d6-7389-7c63-e71a" hidden="false">
      <description>If a unit scores two or more hits with weapons with this ability, you may resolve the hits normally or inflict a single combined attack. When combining attacks, choose one Ghostlight hit to be the primary hit. Resolve only the primary hit; for each other Ghostlight hit, the primary hit gains +1 Strength, -1 AP, +1 Damage, and AT(1), to a maximum of 10 Strength, -6 AP, 4 Damage, and AT(4).</description>
    </rule>
    <rule name="Visitors of the Black Library" id="3a9a-34fa-2b7c-fa10" hidden="false">
      <description>The army has access to Harlequin units. Harlequins can not be the mandatory HQ selection.</description>
    </rule>
  </sharedRules>
  <sharedSelectionEntryGroups>
    <selectionEntryGroup name="Exarch Powers" id="e7a0-25e9-2a4e-f517" hidden="false" collapsible="true">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Bladestorm" hidden="false" id="0b87-88f4-9b6e-f6ae">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="e107-f071-bcc9-c402" includeChildSelections="true" includeChildForces="true"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="40d8-7900-73a1-1378" value="5"/>
          </costs>
          <infoLinks>
            <infoLink name="Bladestorm" id="fe3a-0e14-c473-ac2c" hidden="false" type="rule" targetId="eaab-493d-d022-53fa"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Burning heat" hidden="false" id="59c2-a858-3ed8-9ff7">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="f2d0-2e78-34c1-16ce" includeChildSelections="true" includeChildForces="true"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="40d8-7900-73a1-1378" value="5"/>
          </costs>
          <infoLinks>
            <infoLink name="Burning heat" id="bebf-ddf2-f32a-6084" hidden="false" type="rule" targetId="8201-5e60-1086-085a"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Crack shot" hidden="false" id="2c27-a236-f53e-c858">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="4e53-0b0d-f1d3-8005" includeChildSelections="true" includeChildForces="true"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="40d8-7900-73a1-1378" value="5"/>
          </costs>
          <infoLinks>
            <infoLink name="Crack shot" id="d396-a856-5355-b9af" hidden="false" type="rule" targetId="f2a1-67f4-ea9c-72af"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Crushing blows" hidden="false" id="87b6-e40f-60ae-0f88">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="bc31-b1fe-7582-e6a8" includeChildSelections="true" includeChildForces="true"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="40d8-7900-73a1-1378" value="5"/>
          </costs>
