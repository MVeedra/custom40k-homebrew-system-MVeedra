      </characteristics>
    </profile>
    <profile name="Eldar jetbike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6e46-95e0-bdec-4cfd">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement, +1 Toughness, +1 Wound, a twin shuriken catapult and the ability &quot;Jet bike&quot;. Only for infantry.</characteristic>
      </characteristics>
    </profile>
    <profile name="Faolchu&apos;s wings" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6382-7c9e-4503-4a17">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement and the ability &quot;Jump pack infantry&quot;. Additionally, it gains the &quot;Sky Dive&quot; ability (see Swooping Hawks). Only for infantry.</characteristic>
      </characteristics>
    </profile>
    <profile name="Fire blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f5b9-0a1b-1c18-493b">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains Precision(5+) and cumulative -2 AP. Unique. Can&apos;t be combined with other blades.</characteristic>
      </characteristics>
    </profile>
    <profile name="Forcefield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3e99-197a-f534-4d08">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Ghosthelm" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c789-58cd-5273-4168">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first Perils of the warp attack of the game.</characteristic>
      </characteristics>
    </profile>
    <profile name="Heavy armor plating" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ab09-fd8a-8e7e-4da0">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 3+ save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Hungering blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3196-40d4-35e3-4816">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains cumulative Flurry(4). Unique. Can&apos;t be combined with other blades.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mandiblaster" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6cb3-32dd-dd54-4cde">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During the model&apos;s initiave step, roll a D6. On a 4+, one enemy unit in melee suffers an automatic wound with S:4 AP:-2 D:1.</characteristic>
      </characteristics>
    </profile>
    <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
      </characteristics>
    </profile>
    <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mirrorgaze" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3dbf-dbb4-cc95-420a">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the &quot;Deflect&quot; and &quot;Parry&quot; abilities. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Paragon of fate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e608-3c1b-de37-459f">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, Wounds and Attacks. The model and its attached unit may re-roll any single die per activation. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Paragon of war" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e7a3-9d86-da00-49da">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Strength, Toughness, Wounds and Attacks. It can chose a single Exarch power. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Phoenix gem" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="58d7-cab9-dd15-4dad">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll a die the first time the model is eliminated: 
1,2 - Remove the model.
3,4 - Set it back up with 1 wound. 
5,6 - Set it up again with 2 wounds. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Psychic mastery" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9724-d530-408e-4502">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The models gains +1 to all tests for manifesting a psychic power.</characteristic>
      </characteristics>
    </profile>
    <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
      </characteristics>
    </profile>
    <profile name="Rune armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3f1a-c689-61d9-4a8f">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Runes of warding" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7ef0-b0f6-ba54-49dc">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Add +1 to rolls to deny enemy psychic powers.</characteristic>
      </characteristics>
    </profile>
    <profile name="Shrine relic" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="79d5-d142-26c6-4438">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6&quot; Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
      </characteristics>
    </profile>
