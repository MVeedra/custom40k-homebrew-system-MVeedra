        <profile name="Crystal targeting matrix" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="86c7-c6b3-462f-452c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores negative to hit modifiers from equipment or abilities.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ghostwalk matrix" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="2d47-ca56-23cd-4318">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains "Move through cover".</characteristic>
            </characteristics>
        </profile>
        <profile name="Holo-field" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="553f-886a-926e-46c1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemies must roll twice on the vehicle damage chart and apply the lower result. Does not work on the consecutive rolls for suffering "Heavy structural damage".</characteristic>
            </characteristics>
        </profile>
        <profile name="Improved targeting" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="34d4-53c0-250c-47a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jammer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3841-27f0-9710-4a6e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Equipment such as icons or homing beacons do not function within 6" of the model. Additionally, units arriving via deep strike that land within 12" roll 4D6 instead of 2D6 for scattering.</characteristic>
            </characteristics>
        </profile>
        <profile name="Spirit stones" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="0cd4-e4ef-6109-4fe0">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Star engines" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="a5b5-edc3-3224-4a5c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Fast" ability.</characteristic>
            </characteristics>
        </profile>
