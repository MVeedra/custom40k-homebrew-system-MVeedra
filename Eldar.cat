            <profile name="Headshot" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="36e0-e619-83cd-dbf1">
              <characteristics>
                <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">If an enemy model suffers a wound from the Exitus rifle or pistol but is not eliminated, roll 1D6. On a 3+ the model suffers another wound with no save allowed.</characteristic>
              </characteristics>
            </profile>
            <profile name="Perfect aim" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="ceaf-f37a-6209-dad1">
              <characteristics>
                <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">The model ignores any negative to hit modifications. The player may chose which model in the target unit has to be removed as a casualty.</characteristic>
              </characteristics>
            </profile>
            <profile name="Vindicare Assassin" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="17f0-3a8e-16b4-9b0c">
