    <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3&quot; of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
      </characteristics>
    </profile>
