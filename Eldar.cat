    <profile name="Fate Reader" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6b0c-9f64-c28f-ec87">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Any one die from either player may be re-rolled once per battle round. Unique. Ulthwé only.</characteristic>
      </characteristics>
    </profile>
    <profile name="Master of Ambush" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="75d5-598e-30a9-659a">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">After both players assigned orders during the first battle round, remove up to one unit from your own army and re-redploy it anywhere on the table that is more than 9&quot; away from the enemy deployment zone and units. Unique. Alaitoc only.</characteristic>
      </characteristics>
    </profile>
    <profile name="Natural Leader" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="591c-2cca-b7ba-4f6c">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select up to one friendly unit during each Command phase. All selected units gain a +1 bonus to hit rolls for their next activation. Unique. Biel-Tan only.</characteristic>
      </characteristics>
    </profile>
    <profile name="Enduring Resolve" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1f77-5e03-a9a3-79f0">
      <characteristics>
        <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All to wound rolls against the model suffer a -1 penalty. Unique. Iyanden only.</characteristic>
