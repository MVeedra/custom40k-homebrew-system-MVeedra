                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Atalan bike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0387-ac4c-4f05-4f84">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement, +1 Toughness, +1 Wound, Atalan small arms and the "Bike" type. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Cranial inlay" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cb97-0247-41d6-450f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army adds +1 to rolls during the Reinforcement phase. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Crown of Ascendancy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f30d-1c5b-bbec-43d5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can manifest and deny 1 psychic power per turn. It knows Smite and all powers from the Broodmind discipline. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Cult relic" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b09f-6e1a-0412-4927">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Elixir of Dark Vistas " typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a0e8-dd86-d26c-4070">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Familiar" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e3f5-4da2-1972-4117">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may sacrifice the Familiar to reroll a psychic power manifestation test. While it is alive, the model gains +1 Initiative. Only for psykers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Instinctive counter-strike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ed1c-d4f9-fdc5-4d46">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain the "Counter-Attack" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lash whip" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fd98-4bac-5da8-4333">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one (additional) hit roll per activation in melee.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Pennant of Ascension" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6c89-ef16-375d-440a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains an additional bonus of +1 to the combat result, as well as +1 attack per model. Only for models with a Cult icon. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Pervasion veil" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2f39-1637-f163-4ddb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement and the "Jump pack" rule. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Preternatural senses" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="983c-4803-0faa-47e2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Shadow stalker" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b952-5493-b9b5-481d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Deflect" and "Parry" abilities.</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Synaptic weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7133-811b-ef33-4926">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll all to hit and to wound rolls in melee. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Unwilling Orb" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="85b4-eb87-e83d-4460">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can deny 1 additional psychic power per turn and may deny psychic powers from any range.</characteristic>
            </characteristics>
        </profile>
