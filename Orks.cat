        <profile name="Additional armor" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3542-3867-123a-4dce">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Armored hood" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="b2fb-e1e4-58fa-4be0">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle no longer counts as "Open".</characteristic>
            </characteristics>
        </profile>
        <profile name="Boarding plank" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="5225-3ca1-e9a6-4326">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All passengers in the vehicle can fight normally in melee and be targeted while in the transporter. Only for vehicles with the "Open" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Death roller" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="c0f2-78a7-23da-42c8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model inflicts twice as many wounds when performing a Tank Shock.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grab claw" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="9d81-94a2-4587-4509">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 1D6 when an enemy vehicle is in base contact and is activated. It cannot move on 4+.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grot mechanic" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="a70d-ebad-5b52-4741">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of its activation, the model can attempt to repair drive damage on 4+.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Nozzle drive" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="49fd-0fe2-6aca-446d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle can move an additional 1D6" with an Advance command. On a 1, the model suffers one permanent engine damage. This additional movement is not taken into account when determining how many weapons a vehicle can still fire, or how passengers can use their orders. Not for Walkers.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Red paint" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="d238-ef27-5fb3-4094">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle receives +1" to its movement range. This additional movement is not taken into account when determining how many weapons a vehicle can still fire or how passengers can use their orders.</characteristic>
            </characteristics>
        </profile>
        <profile name="Reinforced battering ram" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="41df-fc6b-36f6-47b1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle can re-roll tests for difficult terrain.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke launcher" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="a551-88ca-b2e1-4ab6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Stikkbombz launcha" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="196b-fca4-cd4d-4784">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle receives an additional weapon: Stikkbombz launcha.</characteristic>
            </characteristics>
        </profile>
        <profile name="Target squig" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="e2bf-a966-18ef-400e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Wrecking ball" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="1f02-325d-7c78-47fd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The vehicle receives an additional weapon and inflicts one automatic hit with S:10 AP:-4 D:3 AP(3) in melee.        </characteristic>
            </characteristics>
        </profile>
