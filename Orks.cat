        <profile name="Ammo grot" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="55c7-4f4a-b937-4255">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can reroll one hit roll with this weapon per round. Must be purchased separately for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Artifact of Gork ... or Mork" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5bcf-12ba-0de7-4b1f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bonesaw" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cfb5-f124-cc92-42a2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the end of its movement, the model can attempt to heal a creature within 3". On a 3+, a model regains up to 2 lost Wounds. On a 1-2, it loses another Wound. Only for Painboys.</characteristic>
            </characteristics>
        </profile>
        <profile name="Boss pole" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d8d2-05f0-7897-468a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Friendly units within a 6" radius receive +1 to their Leadership value.</characteristic>
            </characteristics>
        </profile>
        <profile name="Coppa skullcap" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="26ee-dd59-0240-4cdf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the model manifests a psychic power with a roll of 10 or more, it may use the same psychic power a second time. The target may be changed. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Cybork body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c340-a474-3cce-4da5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model receives a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Eavy armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9ab3-4ee4-c209-4909">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ armor save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Fuel mixagrot" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="45f0-41b1-a1fd-4e5c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, the model can automatically advance 9". For bikes only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gold teeth armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="140d-5a57-16c0-44af">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 3+ armor save and a 5+ invulnerable save. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Kustom force field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b38d-b9dc-f14d-4880">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and an attached unit gain the "Warded" ability against ranged attacks. Only for Big Mek. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lucky stikkz" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e3b7-b8f4-4414-4dd8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can re-roll up to two failed rolls each battle round. For each re-roll that also fails, the model suffers an automatic Wound with not saves allowed.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mega armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="667a-a197-f420-47bd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, a 2+ armor save, and the special rules "Massive(1)" and "Unyielding". Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="More Boom!" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dbbc-4565-fcb6-4d9e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A ranged weapon of the model increases its Strength by 2. Not compatible with "More Dakka!" and "More Zzzap!".</characteristic>
            </characteristics>
        </profile>
        <profile name="More Dakka!" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5afd-2a91-8997-4ecf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A ranged weapon of the model increases its number of shots by 2. Not compatible with "More Boom!" and "More Zzzap!".</characteristic>
            </characteristics>
        </profile>
        <profile name="More Zzzap!" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a089-0ebe-3bd9-4819">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model's ranged weapon gains -1 AP, +1 Damage and the "Overheating" trait. Not compatible with "More Dakka!" and "More Boom!".</characteristic>
            </characteristics>
        </profile>
        <profile name="Moshing honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f63d-ee9c-a382-4f2b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Oil grot" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4a3f-1841-9c9d-47d6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can re-roll one "Mek Tools" roll per battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Precision squig" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="19c9-56a3-b549-40f3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic Skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Rocket pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="01c2-7024-6b13-4807">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model becomes a "Jump pack infantry" unit and gains the "Rocket pack" trait (see Stormboyz). For Infantry only</characteristic>
            </characteristics>
        </profile>
        <profile name="Skorched git remains" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e965-3902-98f4-4c5c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a +1 bonus to manifest psychic powers from the Waaagh! discipline.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Sneakiest Git" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f329-37b2-bd5d-4f30">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the Use cover, Move through cover, Infiltrator and "Throat slittas" traits (see Commands). Only for Infantry. Unique.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Squighog steed" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ef9d-5610-59b2-475c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Strength +1 Toughness, +1 Wound, +1 Attack and the unit type "Bike" and the $Squig$ keyword. Only for Infantry. Only for $Wildorks$.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Squigosaur" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6c87-8062-937c-40a0">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Toughness, +2 Wounds, +1 Attack and the unit type "Bike" and the $Squig$ keyword. Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tellyporta homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5fdc-1bdd-1840-41b3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Thinking cap" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c1a1-763e-7092-4e5b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select an ability during activation: Counter-attack, Favoured enemy, or Tank hunter. The ability is active for the model and the attached unit until the next activation. Unique                                                                                        </characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Waaagh!-Banner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2437-82bb-27d9-454d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains a bonus of +1 to Leadership and Combat resolutions. As long as the banner bearer is alive, Mission objectives that are held by this unit can not be contested by enemy units. Additionally, all models in the unot gain +1 Attack. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Waaagh!-Bike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bea3-c806-e95c-473c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gets +6" Movement, +1 Toughness, +1 Wound, a Dakkagun and the unit type "Bike". For Infantry only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Waaagh!-Trike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c8ae-f6a9-01a3-401e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gets +6" Movement, +1 Toughness, +2 Wounds, three double-barreled Bummstikks, Kill jets and the unit type "Bike". For infantry only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Wildork" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="54ca-eb0a-f92b-422e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model receives the $Wildork$ keyword and a 6+ invulnerability saving throw. Melee hit rolls against vehicles or monstrous creatures receive a +1 bonus and the "Lance(1)" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mek" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="2760-bd28-4083-47fe">
            <characteristics>
                <characteristic name="M" typeId="2734-8af3-55f8-d225">6"&quot;</characteristic>
