            </characteristics>
        </profile>
        <profile name="Cegorach’s Rose" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="453f-1e9f-6069-4c8e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains Deadly(5+) on one of its weapons. If the weapon already has the rule, increase Deadly(x+) by 1. For example Deadly(5+) becomes Deadly(4+). Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Crescendo" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="14df-cc31-dc75-433c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A "Pistol" type weapon of the model gains +1 shot per activation. The point cost is the same as the weapon that gets this equipment. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="D-field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="717f-2c74-39ec-443d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the model makes at least one successfull save during its activation, to hit rolls against the model suffer a cumulative -1 penalty until the start of its next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Eldar jetbike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6e46-95e0-bdec-4cfd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Toughness, +1 Wound, a twin shuriken catapult and the ability "Jet bike". Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mask of Secrets" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bdc3-8b36-3c03-43c2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units that are fleeing from close combat and get caught receive double the amount of automatic hits from this model and its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Phase field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="32ed-eee8-7983-4239">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Stealth" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Relic of the Black Library" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="78a9-9822-35f7-4cf3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Starmist Raiment" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3aa6-274c-4bcb-4e38">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may activate its Starmist Raiment to gain a 3+ invulnerability save until the start of its next activation. Ammunition(1), Unique. </characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Laughing God’s Eye" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="442e-1176-39ab-4eac">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and all friendly units within 6" gain the "Aegis (5+)" ability.</characteristic>
            </characteristics>
        </profile>
