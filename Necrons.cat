            </characteristics>
        </profile>
        <profile name="Skorpekh body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="94eb-7e54-c94a-4bda">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, +1 Initiative, +1 Wound and the ability "Move through cover". Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Solar impulse" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bfdd-3342-9205-41fc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During the model's activation, the solar impulse can be used once to give all units on the table a -1 hit penalty until the end of the battle round. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tesseract labyrinth" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="26fc-b5d4-b545-4f89">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of your activation, pick a wounded enemy model in base contact. It must pass a Strength test or is immediately removed. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tomb world relic" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a1f3-00bb-768d-4305">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
