            </characteristics>
        </profile>
        <profile name="War scythe" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="48f6-4b8a-b638-40a1">
            <characteristics>
                <characteristic name="Range" typeId="17a8-c6d1-4902-3240">-</characteristic>
