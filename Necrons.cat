        <profile name="Orb of reanimation" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="edfc-fc66-b994-4f3c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Can be used during the Reinforcement phase to gain +3 temporary RPoints. Ammo(1), Unique.</characteristic>
            </characteristics>
