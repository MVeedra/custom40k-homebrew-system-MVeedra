            </characteristics>
        </profile>
        <profile name="Atomic energy manipulator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="889d-bf67-dcfe-407c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, the model can boost a friendly infantry unit within 3" range. Roll 1D3: 
1 - The unit gains +1 Strength. 
2 - The unit gains +1 Toughness. 
3 - The unit gets +1 BS and +1 WS. 
Character models cannot be upgraded. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Canoptek cloak" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="013d-d0d1-4aec-4b88">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Jump pack" special rule. At the end of its activation, it can heal a friendly Canoptek unit within 6" for 1 wound, 1 permanent vehicle damage or 1 Hull point.</characteristic>
            </characteristics>
        </profile>
        <profile name="Canoptek control node" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ab4a-4678-d741-4135">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of the activation, pick a single friendly $Canoptek$ unit within 12". It gets +1 to hit rolls until the end of its activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Chronometron" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="830e-f1f5-487d-417f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain a 6+ invulnerability save against ranged attacks. In addition, the model and an attached unit gain a +3 bonus for pursuit rolls.</characteristic>
            </characteristics>
        </profile>
        <profile name="Countertemporal nanomines" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fd53-4b51-5f59-48c3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per battle, this unit can place Countertemporal nanomine while moving. This must be placed within 1" of the unit and more than 3" away from enemy units. The first enemy unit that comes within 3" of the nanomine suffers 1D3+1 wounds with Strength: 4, AP: -4, D: 1. Vehicles suffer 1D3 glancing hits.</characteristic>
            </characteristics>
        </profile>
        <profile name="Empyric Overcharger" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="94b3-8718-e097-42c9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Psykers within 18" suffer a "Perils of the Warp" attack on each double when trying to manifest a psychic power. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Harbinger of Despair" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="42ae-19b6-09a7-4584">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Pick an enemy unit within 18" and roll 3D6 during your activation. If your result is higher than the target's Leadership value, the target gains a Battleshock token.</characteristic>
            </characteristics>
        </profile>
        <profile name="Harbinger of Destruction" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e675-125b-5eeb-4a0b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 5D6 during your activation. For every 4+ an enemy unit within 24" suffers an automatic wound with S:4 AP:-1 Dmg:1, Seeking.</characteristic>
            </characteristics>
        </profile>
        <profile name="Illuminor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="67e0-1e1a-25f1-401f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Rites of Reanimation ability a second time per turn. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lightning field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fc57-5053-88a7-4ac2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units in close combat suffer an automatic wound with S:4 AP:0 D:1 for each wound inflicted on the model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Living Lightning" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0946-69ca-1eab-4132">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 1D6 for every enemy model in the same close combat with this model. On a 4+ it suffers an automatic wound with S:4 AP:-1 D:1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon separately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mindshackel scarab" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9d1e-9906-fc3c-4cd4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Randomly choose an enemy model in base contact. If it fails a Morale test with 3d6, it attacks its own unit. Does not work with units consisting of a single model (like characters). Ammo(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Nightmare shroud" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067e-ecc7-8553-4721">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of firing a weapon, the Nightmare shroud can be used. All enemy units within a 12" radius must pass a Leadership test with a -1 penalty or gain a Battleshock token. Can't be used during Defensive fire. Ammo(1). Unique.</characteristic>
            </characteristics>
        </profile>
