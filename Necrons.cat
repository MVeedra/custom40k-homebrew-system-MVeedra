                <characteristic name="Type" typeId="85b8-b86f-84a1-6a8a">Melee</characteristic>
                <characteristic name="S" typeId="dfe1-ab2e-bf82-b051">+1</characteristic>
                <characteristic name="AP" typeId="5769-5be9-c3dd-1b76">-2</characteristic>
                <characteristic name="D" typeId="40a0-b76f-918f-50a5">1</characteristic>
                <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">Quick(+1)</characteristic>
            </characteristics>
        </profile>
        <profile name="Plasmic lance - Melee" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="7e92-c82d-0c96-424f">
            <characteristics>
                <characteristic name="Range" typeId="17a8-c6d1-4902-3240">-</characteristic>
                <characteristic name="Type" typeId="85b8-b86f-84a1-6a8a">Melee</characteristic>
                <characteristic name="S" typeId="dfe1-ab2e-bf82-b051">+1</characteristic>
                <characteristic name="AP" typeId="5769-5be9-c3dd-1b76">-2</characteristic>
                <characteristic name="D" typeId="40a0-b76f-918f-50a5">1</characteristic>
                <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">Quick(+1)</characteristic>
            </characteristics>
        </profile>
        <profile name="Atomic energy manipulator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="889d-bf67-dcfe-407c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, the model can boost a friendly infantry unit within 3" range. Roll 1D3: 
1 - The unit gains +1 Strength. 
2 - The unit gains +1 Toughness. 
3 - The unit gets +1 BS and +1 WS. 
Character models cannot be upgraded. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Canoptek cloak" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="013d-d0d1-4aec-4b88">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Jump pack" special rule. At the end of its activation, it can heal a friendly Canoptek unit within 6" for 1 wound, 1 permanent vehicle damage or 1 Hull point.</characteristic>
            </characteristics>
        </profile>
        <profile name="Canoptek control node" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ab4a-4678-d741-4135">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of the activation, pick a single friendly $Canoptek$ unit within 12". It gets +1 to hit rolls until the end of its activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Chronometron" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="830e-f1f5-487d-417f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit gain a 6+ invulnerability save against ranged attacks. In addition, the model and an attached unit gain a +3 bonus for pursuit rolls.</characteristic>
            </characteristics>
        </profile>
        <profile name="Countertemporal nanomines" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fd53-4b51-5f59-48c3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per battle, this unit can place Countertemporal nanomine while moving. This must be placed within 1" of the unit and more than 3" away from enemy units. The first enemy unit that comes within 3" of the nanomine suffers 1D3+1 wounds with Strength: 4, AP: -4, D: 1. Vehicles suffer 1D3 glancing hits.</characteristic>
            </characteristics>
        </profile>
        <profile name="Empyric Overcharger" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="94b3-8718-e097-42c9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Psykers within 18" suffer a "Perils of the Warp" attack on each double when trying to manifest a psychic power. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Harbinger of Despair" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="42ae-19b6-09a7-4584">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Pick an enemy unit within 18" and roll 3D6 during your activation. If your result is higher than the target's Leadership value, the target gains a Battleshock token.</characteristic>
            </characteristics>
        </profile>
        <profile name="Harbinger of Destruction" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e675-125b-5eeb-4a0b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 5D6 during your activation. For every 4+ an enemy unit within 24" suffers an automatic wound with S:4 AP:-1 Dmg:1, Seeking.</characteristic>
            </characteristics>
        </profile>
        <profile name="Illuminor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="67e0-1e1a-25f1-401f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Rites of Reanimation ability a second time per turn. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lightning field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fc57-5053-88a7-4ac2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units in close combat suffer an automatic wound with S:4 AP:0 D:1 for each wound inflicted on the model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Living Lightning" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0946-69ca-1eab-4132">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 1D6 for every enemy model in the same close combat with this model. On a 4+ it suffers an automatic wound with S:4 AP:-1 D:1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon separately.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mindshackel scarab" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9d1e-9906-fc3c-4cd4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Randomly choose an enemy model in base contact. If it fails a Morale test with 3d6, it attacks its own unit. Does not work with units consisting of a single model (like characters). Ammo(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Nightmare shroud" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067e-ecc7-8553-4721">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of firing a weapon, the Nightmare shroud can be used. All enemy units within a 12" radius must pass a Leadership test with a -1 penalty or gain a Battleshock token. Can't be used during Defensive fire. Ammo(1). Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Phase adjuster" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8bd2-f3f9-73c4-4be4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Phase shifter" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1d0c-0cbe-5797-4bea">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Sempiternal weave" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ce8b-9950-3490-46ca">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ armor save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Skorpekh body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="94eb-7e54-c94a-4bda">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, +1 Initiative, +1 Wound and the ability "Move through cover". Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Solar impulse" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bfdd-3342-9205-41fc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During the model's activation, the solar impulse can be used once to give all units on the table a -1 hit penalty until the end of the battle round. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tesseract labyrinth" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="26fc-b5d4-b545-4f89">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of your activation, pick a wounded enemy model in base contact. It must pass a Strength test or is immediately removed. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tomb world relic" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a1f3-00bb-768d-4305">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Arise against interlopers" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="ec48-1063-5f39-44e5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, it gains +1 to melee hit rolls until the end of the current battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Awakened by Murder" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f9d6-8991-e2b6-4cb1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Frenzy(1")" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Eternal Conquerors" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="7034-b766-08cb-4cd1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit prevents 1 RPoint from being lost for itself and gains 1 temporary RPoint each Reinforcement phase, if it is within 6" of an objective marker. Only for $Necron$ units.</characteristic>
            </characteristics>
        </profile>
        <profile name="Immovable Phalanx" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="2c42-5b84-ae9f-4293">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses Stand & Shoot, it gains a +1 bonus to armor saves until its next activation. Can't be combined with "Merciless hunters".</characteristic>
            </characteristics>
        </profile>
        <profile name="Interplanetary Invasors" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="dab8-dacd-21ae-4084">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Vehicle units can fire all weapons, if they move up to 12". Only for vehicles.</characteristic>
            </characteristics>
        </profile>
        <profile name="Isolationists" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="6921-478e-15c9-4802">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit's "Rapid Fire" weapons gain +1 Strength when being resolved against targets that are within half weapon range.</characteristic>
            </characteristics>
        </profile>
        <profile name="Masters of the Martial" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="a12b-c47e-c166-400e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one hit roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Merciless Hunters" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="9f6f-a633-5223-4b4f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can fire "Rapid Fire" weapons twice at full range with a "Stand & Shoot" order. Can't be combined with "Immovable phalanx". </characteristic>
            </characteristics>
        </profile>
        <profile name="RAD-wreathed" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="70ab-0f7e-ab41-4da4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units within 3" of the unit suffer a -1 penalty to their Toughness. </characteristic>
            </characteristics>
        </profile>
        <profile name="Relentless Expansionism" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0fe6-7949-adb2-4a91">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Vanguard" ability . Can't be combined with "Translocation beams".</characteristic>
            </characteristics>
        </profile>
        <profile name="Solar Fury" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="7b6d-c15b-2804-4c5c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit's weapons increase their range by 3". </characteristic>
            </characteristics>
        </profile>
        <profile name="Superior Artisans" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="fb8e-083f-12ad-4d46">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one armor penetration or wound roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="The unmerciful Horde" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="7c79-18ef-4319-46a1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll failed Leadership tests.</characteristic>
            </characteristics>
        </profile>
        <profile name="Translocation Beams" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="75ca-d538-c604-4bb9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit automatically advances 6" instead of rolling for it, ignoring terrain. Can't be combined with "Relentless expansionism".</characteristic>
            </characteristics>
        </profile>
        <profile name="Vassal Dynasty" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="7918-c6b0-50d5-4f95">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must select a second Legacy. Each model may only select items from one Legacy armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Vengeful Stars" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="20f6-d5e3-9971-4736">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of the activation, pick a single friendly $Canoptek$ unit within 12". It gets +1 to hit rolls until the end of its activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Warrior Nobles" typeId="equipment_type_id" typeName="Traits" hidden="false" id="1a5e-0922-e344-4efe">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one (additional) hit and one (additional) wound roll per activation. Only for HQ units.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lord" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="0be9-c441-d615-4f46">
            <characteristics>
                <characteristic name="M" typeId="2734-8af3-55f8-d225">6"&quot;</characteristic>
                <characteristic name="WS" typeId="b8b1-cb7e-422b-9e59">2+</characteristic>
                <characteristic name="BS" typeId="2134-4e17-7efb-7cdd">2+</characteristic>
                <characteristic name="S" typeId="355a-95af-e32c-6a76">5</characteristic>
                <characteristic name="T" typeId="f0a6-a47d-9895-24fd">5</characteristic>
