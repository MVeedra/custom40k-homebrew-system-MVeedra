            </characteristics>
        </profile>
        <profile name="Destroyer body" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d493-3891-c007-4438">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Toughness, +1 Wound and the ability "Jet bike". Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gaze of the flame" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d664-5d45-fa41-4f29">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units gain no bonus attack when charging and suffer a -1 penalty to Leadership while in melee.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grand strategist" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a710-3e64-a54f-47f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">After all units have been placed in the Deployment phase, the Lord may remove and redeploy one of his units. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Orb of reanimation" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="edfc-fc66-b994-4f3c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Can be used during the Reinforcement phase to gain +3 temporary RPoints. Ammo(1), Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Phylactery" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8101-efe5-9e34-4e84">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll a die the first time the Lord is eliminated. 
1,2 - Remove the model.
3,4 - Set it back up with 1 wound.
5,6 - Set it up again with 2 wounds. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Shadow ankh" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="32d0-4430-6103-4f28">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may attempt to deny one psychic power per battle round and receives a +1 bonus to the roll.</characteristic>
            </characteristics>
        </profile>
        <profile name="Translocation shroud" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8c1f-8146-f043-4e6c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains "Anti-Grav" and always advances 6" when using an "Advance" order without rolling for it.</characteristic>
            </characteristics>
        </profile>
        <profile name="Veil of darkness" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c13b-3f5c-81e5-4c95">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The Lord can use a "Stand & Shoot" order to immediately redeploy himself and an attached unit using the deep strike rules. Additionally, the model and its attached unit gain the "Deep strike" ability. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bloodshroud" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4a9e-2a86-89e7-4346">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During its activation, the model inflicts 1 Mortal Wound on a 3+ against all enemy units within 3". Novokh only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Dominance Weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8674-b532-d5b7-4d7a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Decimate" ability with all melee attacks. Mephrit only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Domination Staff" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="291a-f04e-708c-47d4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select one enemy model in direct base contact. The model suffers a -2 penalty to its Initiative for the remaining battleround. Szarekhan only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Starfire Mantle" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2536-e932-6637-4faf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">When the model moves over an enemy unit, it inflicts 1 Mortal Wound. Nephrekh only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Stormshroud" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3c76-d3f0-8794-4f0d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains the "Soul burn(5+)" ability. Sautekh only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Yth Engrams" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="42a4-aa2e-7f2c-4ef1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll any one die per activation. Nihilakh only.</characteristic>
            </characteristics>
        </profile>
