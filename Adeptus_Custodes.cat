        <profile name="Praesidius" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ae2b-6875-c53d-43ad">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Stealth" ability. Unique.</characteristic>
            </characteristics>
        </profile>
