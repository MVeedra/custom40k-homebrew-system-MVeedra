            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Radiant mantle" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6df5-edff-08e6-4a55">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units suffer a cumulative -1 to their hit rolls against the model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Superior Creation" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="63ed-629f-913c-4cd9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll a die the first time the model is eliminated. 
1,2 - Remove the model.
3,4 - Set it back up with 1 wound.
5,6 - Set it up again with 2 wounds. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Vault weapon" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="4c59-0f48-b96a-4c40">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Each improvement is unique per army.</characteristic>
            </characteristics>
        </profile>
