        <profile name="Additional armor" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3542-3867-123a-4dce">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Broad spectrum data-tether" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="8252-8273-10d6-4e80">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Friendly units within 12" radius gain +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Cognis manipulator" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="de21-f5d5-a678-42d5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model repairs one temporary or permanent damage (including missing Hull Points) on a 4+ during each Reinforcement phase.</characteristic>
            </characteristics>
        </profile>
        <profile name="Improved targeting" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="34d4-53c0-250c-47a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Infoslave skull" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3e50-de3d-c5e4-4d11">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit ignores the to hit penalty for Defensive fire.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jammer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3841-27f0-9710-4a6e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Equipment such as icons or homing beacons do not function within 6" of the model. Additionally, units arriving via deepstrike that land within 12" roll 4D6 instead of 2D6 for scattering.</characteristic>
            </characteristics>
        </profile>
        <profile name="Machine spirit" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="c7f6-a468-82f9-46dd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can always fire a single weapon with BS(4+), no matter how much temporary weapon damage it has suffered.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mindscanner probe" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="5bb4-899c-330a-40f5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If a friendly unit within 6" gets charged by an enemy, the enemy unit does not receive any bonus (f.e. bonus attacks) for charging.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
