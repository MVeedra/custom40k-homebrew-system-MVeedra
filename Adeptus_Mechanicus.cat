    <sharedRules>
        <rule name="Cognis" id="80f5-20b2-c114-4ff3" hidden="false">
            <description>The weapon reduces its total penalty to hit rolls in ranged combat by -1, down to a minimum of 0.</description>
        </rule>
        <rule name="Luminagen" id="2e3c-d600-7162-477d" hidden="false">
            <description>A unit that suffers one or more unsaved Wounds, glancing or penetrating hits caused by a weapon with this special rule counts its cover saves as being 1 point worse than normal until the end of the battle round. Furthermore, they suffer an additional -1 to hit penalty for Defensive fire.</description>
        </rule>
        <rule name="Tesla" id="a46e-c5c8-0256-4fc9" hidden="false">
            <description>To hit rolls of 5+ are always successful and the target suffers 2 additional automatic hits.</description>
        </rule>
        <rule name="Advisor" id="400a-74e8-a20d-4b3e" hidden="false">
            <description>For every HQ selection, one Skitarii Marshal may be selected without taking up an HQ slot.</description>
        </rule>
        <rule name="Servo-skull Uplink" id="cb7e-9d5c-666d-4598" hidden="false">
            <description>The model and its attached unit may re-roll one to hit and one to wound roll each battle round.</description>
        </rule>
        <rule name="Blessing of the Omnissiah" id="daee-0a90-e491-4172" hidden="false">
            <description>At the end of its move, the model may attempt to repair a vehicle within 6". On a 4+, one "Weapon destroyed" or "Engine damage" result is removed from the vehicle, or 1 hull point is restored. Alternatively, a vehicle within 6" can reroll a hit roll and a wound or armor penetration roll.</description>
        </rule>
        <rule name="Master of the Machines" id="7509-f6f5-3b21-44f0" hidden="false">
            <description>Can sing 1 canticle per battle round. A canticle is successfully performed on a roll of 3+. Knows all Canticles of the Omnissiah.</description>
        </rule>
        <rule name="Mechandrite harness" id="d001-d7c7-40c0-4487" hidden="false">
            <description>The model may use up to three ranged weapons per activation, regardless of their type.</description>
        </rule>
        <rule name="Datasmith" id="e8aa-d4e0-d0f3-470d" hidden="false">
            <description>Improved Battle Protocols - If the model is attached to a unit of Kastelan Robots, the bonus from their Battle Protocols is improved by +1.</description>
        </rule>
        <rule name="Dominus" id="bce1-b29f-fc93-47dd" hidden="false">
            <description>Improved Master of the Machines - The model may use Master of the Machines one additional time per activation and the roll is successfull on a 2+.</description>
        </rule>
        <rule name="Engineseer" id="115d-3300-2660-4a59" hidden="false">
            <description>Improved Blessing of the Omnissiah - The model may use Blessing of the Omnissiah one additional time per activation and the roll is successfull on a 3+.</description>
        </rule>
        <rule name="Manipulus" id="e1f5-1e1a-6997-4542" hidden="false">
            <description>Galvanic Field - The model and its attached unit's Arc, Galvanic and Radium weapons increase their range by 6". Additionally, their AP increases by -1.</description>
        </rule>
        <rule name="Technoarcheologist" id="8625-320a-79a5-4597" hidden="false">
            <description>Seekers of Divine Arcana - The model and its attached unit gain the "Warded" ability while within 6" of an objective. Additionally, the model and its attached unit gain "Objective secured!".</description>
        </rule>
        <rule name="Bionics" id="74ad-7d8a-27f8-4aac" hidden="false">
            <description>The model receives a 6+ invulnerability save.</description>
        </rule>
        <rule name="Sniper" id="34f3-b13b-c76e-4a7e" hidden="false">
            <description>A model equipped with a Transuranic arquebus improves its BS by +1.</description>
        </rule>
        <rule name="Rad-saturation" id="d3bb-47c2-e594-4ea3" hidden="false">
            <description>Enemy models in direct base contact suffer a -1 penalty to their Toughness.</description>
        </rule>
        <rule name="Voltagheist Field" id="ca23-c578-74e5-42f3" hidden="false">
            <description>The model gains a 4+ invulnerability save.</description>
        </rule>
        <rule name="Siphoned Vigour" id="d501-98db-6cba-4561" hidden="false">
            <description>Everytime this unit caused an unsaved Wound, one previously slain model is restored to the unit.</description>
        </rule>
        <rule name="Enhanced Bionics" id="e37d-ea88-d281-410f" hidden="false">
            <description>The model receives a 5+ invulnerability save.</description>
        </rule>
        <rule name="Sky Dive" id="ec03-77c2-80d7-4330" hidden="false">
            <description>Once per game, at the start of their activation, the unit may use a Stand & Shoot order to be immediately re-deployed anywhere on the battlefield. They must keep a minimum distance of 6" to enemy models.</description>
        </rule>
        <rule name="Target aquired" id="7bcf-8c18-9099-460e" hidden="false">
            <description>Select one enemy unit that was hit by this unit during the activation. The next friendly unit firing on the same target can re-roll one failed to hit and wound roll.</description>
        </rule>
        <rule name="Repulsor Grid" id="a26b-f46c-e3e4-4f36" hidden="false">
            <description>The model gains a 5+ invulnerability save.</description>
        </rule>
        <rule name="Battle Protocols" id="ce94-fb26-de49-458f" hidden="false">
            <description>Select one Battle Protocol during each activation
- Aegis All models in the unit gain +1 Toughness. This is the default selection in the first battle round until the first actual activation.
- Conqueror All models in the unit gain +1 WS.
- Protector All models in the unit gain +1 BS.</description>
        </rule>
        <rule name="Emanatus force field" id="b998-5715-d52b-4d58" hidden="false">
            <description>The model gains a 5+ invulnerability save.</description>
        </rule>
        <rule name="Icarus array" id="254b-56b1-7a4f-4bb9" hidden="false">
            <description>The model may fire with all three weapons at the same target each activation.</description>
        </rule>
        <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
            <description>This model has a transport capacity of 12 infantry models.</description>
        </rule>
    </sharedRules>
