        <profile name="Relic of the Forgeworld" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f3a3-98ab-23aa-4e3e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Sacrifactum Autorepulsor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="52b0-9af0-069a-4cee">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units receive a -2" movement penalty when charging the model or its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Serberys steed" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0f9d-cb1b-04c2-4884">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement, +1 Toughness, +1 Wound, Sulphur breath and the "Bike" type. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Stasis field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3e38-7089-b29a-469f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may use its Stasis field once per game to receive a 2+ invulverability save until its next activation. It can't use any weapons or abilities while the Stasis field is active.</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
