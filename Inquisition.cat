                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Xenos equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Plate armour" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="829e-33b4-fbac-417f">
