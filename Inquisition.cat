        <profile name="Aquila Imperialis_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d6c5-ed9f-938f-4991">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Auspex scanner _Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fc1e-8b0b-ee7c-4081">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit has not already activated this turn, it may immediately use up its order and fire at an enemy unit within 18" that is deployed as reinforcement as if it had been given the "Stand & Shoot" order. The attack resolves after the enemy unit has been deployed and before it takes another action.
</characteristic>
            </characteristics>
        </profile>
        <profile name="Bionics_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc95-b995-98d3-4487">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 6+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Combat shield_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="13f4-76e7-e24d-41ed">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Dread reputation_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f3a9-ce76-bf7b-4179">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units within a 6" radius suffer -1 to their Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Esoteric knowledge_Terminator " typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6b73-a358-4677-4b9c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit may reroll one die per battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Empyrian brain mines_Terminator " typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bb13-78ce-d6ca-4560">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Nominate one enemy model in direct base contact during its own activation. The target must pass an Initiative test or can't attack this battle round. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Familiar_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5d07-c92b-b5d1-4804">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may sacrifice the Familiar to reroll a psychic power manifestation test. While it is alive, the model gains +1 Initiative. Only for psykers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gamma psyker_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="706d-b78f-8514-48f5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can manifest one additional power per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grimoire of True Names_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="75ed-f7b4-2a55-4471">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One model in direct base contact suffers -1 penalties to its WS, Initiatives and Attacks, up to a minimum of 1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hexagram warding runes_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="60ab-33d9-3acc-410e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models in direct base contact suffer a -1 penalty to their invulnerability saves.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jump pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="40a2-8813-f362-4d71">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Jump pack" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Liber Heresius_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4eee-8ac2-54e1-49ee">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The bearer may pick any two veteran abilites to be in effect for themselves and their attached unit. The veteran abilities can be changed each activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5fb2-2db9-6cfe-4bf5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted armor_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c51e-f2ff-ad84-468c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="29c5-07d7-c4cd-44d4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="No escape_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="67b9-72cd-a9cd-4719">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Fleeing units are automatically caught up in melee and receive twice the amount of hits from each pursuing model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ordo Hereticus_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5481-0130-1a03-41c3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Hereticus equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ordo Malleus_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a436-90ec-a33b-4807">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Malleus equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ordo Xenos_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="af1b-805e-63d9-40af">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Xenos equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Plate armour" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="829e-33b4-fbac-417f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Power amor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9cda-6ad9-b4c4-49f2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 3+ save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Praesidium Protectiva_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5d40-3259-4445-4d9f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psyoccolum_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc59-4cd1-3758-474e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit may reroll all to hit dice against a psyker and its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psybolt ammunition_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="96f0-b3fb-5fcc-4a5d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All ranged weapon of the model gain +1 Strength. Only works on weapons with Strength 4 or below.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purified weapon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="42d8-870a-991c-495f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Before setting up units, pick one of the purified powers below and add it to one melee weapon of the model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="483a-136a-bf22-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity seal_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b5af-04f8-5655-4cc7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy psykers suffer a -1 penalty to manifest a power when they target the model or its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Refractor field_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2d43-f3a4-e866-4216">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Relic of the Ordo_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2bf8-8c37-8224-4ebf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Servo skull" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3f89-a872-acb7-4db8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Place a "Servo skull" token during the Rally phase of the first battle round anywhere on the battlefield. A friendly unit arriving within 3" of the token via Deep strike does not scatter. If an enemy unit moves within 12" of the token, it is removed from the game. Can be taken up to three times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Special energy cells_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8368-3ddf-8198-4267">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Every laser weapon of the model gains +1 damage.</characteristic>
            </characteristics>
        </profile>
        <profile name="Special issue ammunition_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="db44-c308-e6cc-48fb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Every bolt weapon of the model may select one advantage per activation: 
- Seeking
- Poison(3+)
- +6" range and -1 AP </characteristic>
            </characteristics>
        </profile>
        <profile name="Spy network_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="33fa-98d7-147d-424a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army gains +1 to its initiative roll once per game. Can be chosen to apply after both sides rolled their dice for initiative.</characteristic>
            </characteristics>
        </profile>
        <profile name="Storm shield_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="13f1-5e22-ab8d-4f7f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the abilities "Deflect" and "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e8ef-74b5-833e-4609">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0855-9418-c2e4-4ac1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Terminator armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="59c7-e134-e2cc-43d3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, +1 Attack, 2+ armor save, 5+ invulnerable save, and the abilities "Massive(1)," "Shock Troops," and "Unyielding." Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tesseract labyrinth_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3be8-52f5-0d2b-4992">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of your activation, pick a wounded enemy model in base contact. It must pass a Strength test or is immediately removed. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Throne of Judgement" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f235-6acf-8cc5-4055">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +2 Strength, +2 Toughness, +1 Wound and the ability "Monstrous Infantry". Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bb23-80bb-c60d-4191">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Uluméathi Plasma Syphon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0625-0ea5-b7d3-4290">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models within 18" suffer a -1 penalty to Strength, AP and Damage to weapons with an "Overcharged" profile (applies to all profiles of the affected weapons), to a minimum of 1 each.</characteristic>
            </characteristics>
        </profile>
        <profile name="Universal anathema_Terminator" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="947e-643b-8ac0-43eb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All melee weapons of the model gain the Poison(2+) ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blitz Attack" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f6d7-fb59-bba0-4647">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can fire Assault weapons, Grenades and Pistols without a to hit penalty with Advance and Charge orders.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bolter Drill" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0d5b-a7bb-c188-426f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Deflagrate(5+)" ability with Bolt weapons. Does not apply to "Heavy" weapons.</characteristic>
            </characteristics>
        </profile>
        <profile name="Codex Discipline" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0a8d-9883-7968-4202">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Expanded Armory" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f2a1-314f-906e-4c1a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must select a second Legacy. Each model may only select items from one Legacy armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Forged in Battle" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f427-8fa4-30ba-4914">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one armor penetration or wound roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Knowledge is Power" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="6f3c-d3f0-a63a-4779">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can re-roll one psychic test per activation. Only for Psykers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Path of Damnation" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="5fca-a48c-fffa-4b97">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must include a single "Demon weapon" from the "Chaos Space Marines" codex. The Demon weapon ability can be from any armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity above All" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="084c-ebb7-f225-4558">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One non-character model per squad with access to gear from the Armory can be upgraded to an Apothecary and gains the "Narthecium" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Rapid Deployment" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="9f27-66e5-ccd2-4c1a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Haste(2")" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Red Thirst" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="00f2-1e13-ee71-4ed5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, it gains +1 Strength until the end of the current battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Righteous Wrath" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0fd3-aac3-0792-46e3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Frenzy(1")" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Siege Experts" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f560-ad13-f509-4dd7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Sunder(1)" ability for all ranged attacks.</characteristic>
            </characteristics>
        </profile>
        <profile name="Sons of Mars" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="6168-cb23-928e-4b6c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One non-character model per squad with access to gear from the Armory can be upgraded to a Techmarine and gains the "Blessing of the Omnissiah" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Stalwart" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="b5ac-9226-6c59-407c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can reroll one armor save per battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Stoic" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="4871-9dd4-8aca-40b4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit does not suffer the to hit penalty from Defensive Fire.</characteristic>
            </characteristics>
        </profile>
        <profile name="Strike from the Shadows" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="ab64-27eb-efb6-402b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the benefit of light cover until its first activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Flesh is Weak" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="8753-671c-edf7-4735">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Creature models gain a 6+ invulnerability save. Vehicles can use the "Blessing of the Omnissiah" ability (See Techmarine) on themselves, but only for repairs. Only for creature models that do not already have an invulnerability save from their datasheet or Armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Unleashed Hunters" typeId="equipment_type_id" typeName="Traits" hidden="false" id="17ab-230e-c426-466d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, it gains +1 to melee hit rolls until the end of the current battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Arbites" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="a059-3ee6-0424-44a4">
            <characteristics>
                <characteristic name="M" typeId="2734-8af3-55f8-d225">6"&quot;</characteristic>
                <characteristic name="WS" typeId="b8b1-cb7e-422b-9e59">4+</characteristic>
                <characteristic name="BS" typeId="2134-4e17-7efb-7cdd">4+</characteristic>
                <characteristic name="S" typeId="355a-95af-e32c-6a76">3</characteristic>
