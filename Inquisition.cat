        <profile name="Aquila Imperialis_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="d6c5-ed9f-938f-4991">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Auspex scanner _Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="fc1e-8b0b-ee7c-4081">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit has not already activated this turn, it may immediately use up its order and fire at an enemy unit within 18" that is deployed as reinforcement as if it had been given the "Stand & Shoot" order. The attack resolves after the enemy unit has been deployed and before it takes another action.
</characteristic>
            </characteristics>
        </profile>
        <profile name="Bionics_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc95-b995-98d3-4487">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 6+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Combat shield_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="13f4-76e7-e24d-41ed">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Dread reputation_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f3a9-ce76-bf7b-4179">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units within a 6" radius suffer -1 to their Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Esoteric knowledge_Terminator " typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6b73-a358-4677-4b9c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit may reroll one die per battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Empyrian brain mines_Terminator " typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bb13-78ce-d6ca-4560">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Nominate one enemy model in direct base contact during its own activation. The target must pass an Initiative test or can't attack this battle round. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Familiar_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5d07-c92b-b5d1-4804">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may sacrifice the Familiar to reroll a psychic power manifestation test. While it is alive, the model gains +1 Initiative. Only for psykers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gamma psyker_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="706d-b78f-8514-48f5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can manifest one additional power per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grimoire of True Names_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="75ed-f7b4-2a55-4471">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One model in direct base contact suffers -1 penalties to its WS, Initiatives and Attacks, up to a minimum of 1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hexagram warding runes_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="60ab-33d9-3acc-410e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models in direct base contact suffer a -1 penalty to their invulnerability saves.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jump pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="40a2-8813-f362-4d71">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Jump pack" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Liber Heresius_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4eee-8ac2-54e1-49ee">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The bearer may pick any two veteran abilites to be in effect for themselves and their attached unit. The veteran abilities can be changed each activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5fb2-2db9-6cfe-4bf5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted armor_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c51e-f2ff-ad84-468c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="29c5-07d7-c4cd-44d4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="No escape_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="67b9-72cd-a9cd-4719">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Fleeing units are automatically caught up in melee and receive twice the amount of hits from each pursuing model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ordo Hereticus_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5481-0130-1a03-41c3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Hereticus equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Ordo Malleus_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a436-90ec-a33b-4807">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and further units from this codex get access to Ordo Malleus equipment. Every model can only pick one Ordo allegiance. Only for Inquisitors.</characteristic>
            </characteristics>
        </profile>
