            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psyoccolum_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc59-4cd1-3758-474e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its attached unit may reroll all to hit dice against a psyker and its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psybolt ammunition_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="96f0-b3fb-5fcc-4a5d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All ranged weapon of the model gain +1 Strength. Only works on weapons with Strength 4 or below.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purified weapon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="42d8-870a-991c-495f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Before setting up units, pick one of the purified powers below and add it to one melee weapon of the model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="483a-136a-bf22-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity seal_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b5af-04f8-5655-4cc7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy psykers suffer a -1 penalty to manifest a power when they target the model or its attached unit.</characteristic>
            </characteristics>
        </profile>
        <profile name="Refractor field_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2d43-f3a4-e866-4216">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Relic of the Ordo_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2bf8-8c37-8224-4ebf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Servo skull" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3f89-a872-acb7-4db8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Place a "Servo skull" token during the Rally phase of the first battle round anywhere on the battlefield. A friendly unit arriving within 3" of the token via Deep strike does not scatter. If an enemy unit moves within 12" of the token, it is removed from the game. Can be taken up to three times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Special energy cells_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8368-3ddf-8198-4267">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Every laser weapon of the model gains +1 damage.</characteristic>
            </characteristics>
        </profile>
        <profile name="Special issue ammunition_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="db44-c308-e6cc-48fb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Every bolt weapon of the model may select one advantage per activation: 
- Seeking
- Poison(3+)
- +6" range and -1 AP </characteristic>
            </characteristics>
        </profile>
        <profile name="Spy network_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="33fa-98d7-147d-424a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army gains +1 to its initiative roll once per game. Can be chosen to apply after both sides rolled their dice for initiative.</characteristic>
            </characteristics>
        </profile>
        <profile name="Storm shield_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="13f1-5e22-ab8d-4f7f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the abilities "Deflect" and "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e8ef-74b5-833e-4609">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0855-9418-c2e4-4ac1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Terminator armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="59c7-e134-e2cc-43d3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, +1 Attack, 2+ armor save, 5+ invulnerable save, and the abilities "Massive(1)," "Shock Troops," and "Unyielding." Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tesseract labyrinth_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3be8-52f5-0d2b-4992">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">At the start of your activation, pick a wounded enemy model in base contact. It must pass a Strength test or is immediately removed. One use only.</characteristic>
            </characteristics>
        </profile>
        <profile name="Throne of Judgement" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f235-6acf-8cc5-4055">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +2 Strength, +2 Toughness, +1 Wound and the ability "Monstrous Infantry". Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bb23-80bb-c60d-4191">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Uluméathi Plasma Syphon_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0625-0ea5-b7d3-4290">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models within 18" suffer a -1 penalty to Strength, AP and Damage to weapons with an "Overcharged" profile (applies to all profiles of the affected weapons), to a minimum of 1 each.</characteristic>
            </characteristics>
        </profile>
        <profile name="Universal anathema_Terminator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="947e-643b-8ac0-43eb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All melee weapons of the model gain the Poison(2+) ability.</characteristic>
            </characteristics>
        </profile>
