    <sharedRules>
        <rule name="Psyker" id="943c-18af-a1bb-44ed" hidden="false">
            <description>A Psyker can cast 1 psychic power and dispel 1 psychic power per round. A Psyker knows Smite, as well as one psychic power from a chosen psychic discipline.</description>
        </rule>
        <rule name="Inquisitorial requisiton" id="2614-0c2a-5cf3-40ca" hidden="false">
            <description>The Inquisitor got additional access to a single weapon or wargear item from any Imperial faction. Requirements like specific traits or "Only for xy" must still be met. Wargear that got the same description or ability like an item from their own armory can't be taken.</description>
        </rule>
        <rule name="Inquisitor Lord" id="be43-0cb8-2593-4cef" hidden="false">
            <description>The Inquisitor Lord may purchase one additional item from any Imperial faction.</description>
        </rule>
        <rule name="Arbites shield" id="9e9b-03c3-2bb7-47c9" hidden="false">
            <description>The model gains "Deflect" and "Parry".</description>
        </rule>
        <rule name="Monofilament" id="2ef5-cbe9-5de7-4e92" hidden="false">
            <description>If the target enemy unit is in cover and at least one hit has been scored with the weapon, the terrain counts as difficult and dangerous terrain until the end of the next activation of the target unit.</description>
        </rule>
        <rule name="Arco-flagellant" id="ed44-f76b-5787-452c" hidden="false">
            <description>Every Arco-flagellant has the "Berserker(5+)" and "Blind rage" special ability.</description>
        </rule>
        <rule name="Bodyguard" id="e576-4c2d-47ea-4f07" hidden="false">
            <description>Every Acolyte has the "Bodyguard" special ability.</description>
        </rule>
        <rule name="Devout" id="0927-5fa6-fe4e-4956" hidden="false">
            <description>A Missionary can recite 1 hymn per turn. A hymn is successfully recited on a roll of 3+. A missionary knows a prayer from the hymns of battle.</description>
        </rule>
        <rule name="Narthecium" id="bffa-50c8-09de-47b4" hidden="false">
            <description>Once per turn, the damage of a wound against the model or attached unit can be reduced by 1. The ability must be declared after armor and invulnerability saves. Does not work against weapons with a strength of 8 or above.</description>
        </rule>
        <rule name="Pariah" id="07c4-3937-4f7d-4451" hidden="false">
            <description>While a Penitent is alive, the unit gains the "Aegis(4+)" special ability.</description>
        </rule>
        <rule name="Servitor" id="6ece-b1d2-81a4-465d" hidden="false">
            <description>As long as the Inquisitor is alive, Servitors get +1 to hit rolls.</description>
        </rule>
        <rule name="Wise Guidance" id="cff8-4975-dd3b-43f7" hidden="false">
            <description>While a Sage is alive in the unit, all weapons in the unit gain Deflagration(5+).</description>
        </rule>
        <rule name="Aura of Faith" id="e340-a196-446c-460e" hidden="false">
            <description>While an Exorcist is alive in the unit, all models gain a 5+ invulnerability save against melee weapons.</description>
        </rule>
        <rule name="Jokaero Digital Weapons" id="1484-671f-0c53-435e" hidden="false">
            <description>All Jokaero in the squad can fire the same weapon each round Heavy flamer, Lascannon, Multi-melta. All weapons fired by a Jokaero have the "Assault" type.</description>
        </rule>
        <rule name="Psionic Flare" id="2d6f-1e76-d30a-4255" hidden="false">
            <description>A friendly unit arriving via deep strike does not scatter when set up within 6" of the Mystic. Increase the range by 6" for each additional Mystic.</description>
        </rule>
        <rule name="Warp shield" id="4ed9-1897-1c43-4d0b" hidden="false">
            <description>While the Daemonhost is alive in the unit, all models gain a 5+ invulnerability save against ranged weapons.</description>
        </rule>
        <rule name="Archaeotech Enhancement" id="ec94-da15-8687-4045" hidden="false">
            <description>While an Archaeotech Researcher is alive in the unit, all weapons in the unit gain Armor piercing(5+).</description>
        </rule>
        <rule name="Know Your Enemy" id="5be1-ea8e-8914-4b29" hidden="false">
            <description>As long as a Xenologist is alive in the unit, it gains the "Favoured enemy" special rule against all Xeno factions.</description>
        </rule>
        <rule name="Leadership" id="013a-5a77-2212-43bc" hidden="false">
            <description>As long as an Alien World Scout is alive in the unit, it gains the "Use Cover" and "Move Through Cover" special rule.</description>
        </rule>
        <rule name="Sniper" id="34f3-b13b-c76e-4a7e" hidden="false">
            <description>Models equipped with a Sniper rifle get a +1 bonus to their BS.</description>
        </rule>
        <rule name="Lightning reflexes" id="9799-edf4-e2a0-48ea" hidden="false">
            <description>The model gains a 5+ invulnerability save.</description>
        </rule>
        <rule name="Assault ramp" id="a90d-3724-7f70-4d75" hidden="false">
            <description>Passengers can still make a 6" charge move after the vehicle moves and they exit.</description>
        </rule>
        <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
            <description>This model has a transport capacity of 12 infantry models.</description>
        </rule>
        <rule name="Infernum halo-launcher" id="b6c3-557b-2b6f-4253" hidden="false">
            <description>Enemy weapons do not get any bonus for "Anti-Air" abilities.</description>
        </rule>
    </sharedRules>
    <sharedSelectionEntryGroups>
    </sharedSelectionEntryGroups>
    <categoryEntries>
    </categoryEntries>
    <catalogueLinks>
    </catalogueLinks>
</catalogue>