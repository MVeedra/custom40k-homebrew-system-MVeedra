                <characteristic name="A" typeId="2813-4494-0abe-7149">2</characteristic>
                <characteristic name="LD" typeId="1a6c-9e94-a0f5-84ec">9</characteristic>
                <characteristic name="SV" typeId="512f-e34e-70e2-c6d9">5+</characteristic>
            </characteristics>
        </profile>
        <profile name="Equalisers" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="ab4d-9fa3-8b77-4556">
            <characteristics>
                <characteristic name="Range" typeId="17a8-c6d1-4902-3240">-</characteristic>
