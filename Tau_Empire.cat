        </profile>
        <profile name="Blademaster" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2cad-55e0-79f7-4342">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may chose to either gain the "Armor piercing(5+)" or "Parry" ability during each activation. "Parry" is the default ability. Only for Ethereals. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bonding knife" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4c24-dffa-5220-49f0">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model and its unit may re-roll failed Leadership tests.</characteristic>
            </characteristics>
        </profile>
        <profile name="Drone controller" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5a72-6b2d-db7d-42fb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can be accompanied by up to two Tau Drones. The Drones are subject to "Drone protocols" (see Tau Drones).</characteristic>
            </characteristics>
        </profile>
        <profile name="Ejection system" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9156-2f6f-e8d1-4e5b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the model loses its last wound, replace it with a pilot. The model loses 2 Strength, 2 Toughness, got 1 Wound and a Pulse pistol.</characteristic>
            </characteristics>
        </profile>
        <profile name="Failsafe detonator" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="05d6-0ecd-7dc2-4947">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Activate when the model or its unit are fleeing from melee. Move the unit as normal, while the model stays in place. All remaining models within 6" suffer an automatic hit with Strength 8, AP 0, Damage 1. Remaining units may not pursue the fleeing unit. Remove the model that used the Failsafe detonator afterwards.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hover drone" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7c9c-5c83-ea6c-4c58">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Toughness, +1 Wound and the "Jet bike" ability. Only for Ethereals.</characteristic>
            </characteristics>
        </profile>
        <profile name="Iridium armor plate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="54fa-4423-47c2-4347">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ armor safe and loses 6" movement. Cant' be combined with other battlesuits.</characteristic>
            </characteristics>
        </profile>
        <profile name="Krootox steed" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="48d6-b97b-89de-457b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +2 Strength, +2 Toughness, +2 Wounds, a 5+ Save and the "Bike" ability. Only for Kroot Shapers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Markerlight" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="909e-a6f1-3be3-4014">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a Markerlight, see Index. Only for Infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted suit" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9890-dd13-9666-45b3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ save. Can be combined with other battlesuits.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
            </characteristics>
        </profile>
        <profile name="No longer flesh and blood" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8a9f-828e-d0f2-4641">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a Leadership value of 10. Can't be given to a mandatory HQ selection. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Paradox of Duality" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c1e2-3d2a-c6b0-449f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 1D6 after suffering an unsaved Wound. If the roll is lower than the inversed AP of the weapon, the damage is nullified. Example: If a weapon with AP:-3 causes the wound, the roll needs to be 1 or 2 to be successfull (lower than 3). A 6 is always a failure. Only for Ethereals. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Prototype system" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="248d-52e0-1f80-4076">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Puretide engram neurochip" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cc1c-f081-14cb-4bc3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">During your activation, pick one ability: Counter-attack, Favored enemy, Furious charge or Tank hunter. The ability is active for the model and its attached unit until their next activation. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Stimulant injector" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6d75-30a4-3f01-430d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save. Does not work against weapons with strength 8 and above.</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Tactical philosophies" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="da41-93d0-9193-40e6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select and announce which one of the philosophies you use at the beginning of the deployment. Unique.
1. Kauyon
- Select up to one mission objective or friendly unit as "bait" in any combination for every started 1500 points of game size and announce them to all other players after you decided who places the first unit in the deployment phase.
- All friendly units (except the bait itself) gain +1 Strength for ranged attacks against enemy units that are within 6" range of any bait.
2. Mont'ka
- All units may be set up using the rules for "Deep strike".
- If a unit already got this ability, it reduces the scatter distance by 1D6 for itself.
- In addition to the regular reserve rolls, one unit automatically arrives from reserves each round.
3. Rinyon
- All units get the "Outflank" ability.
- All units automatically advance 6" instead of rolling for it.
4. Rip'yka
- Each time after a unit from this codex shoots at an enemy unit, the enemy unit receives two Markerlight tokens afterwards.</characteristic>
            </characteristics>
        </profile>
        <profile name="Talisman protection chip" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8c3b-b665-f3b9-4bf4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may attempt to deny one psychic power per battle round and receives a +1 bonus to the roll.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="XV22 Stalker battlesuit" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="39fd-f7d9-0fb4-465e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The models gains the +1 Initiative, as well as the "Infiltrator" and "Stealth" ability. Can't be combined with other battlesuits.</characteristic>
            </characteristics>
        </profile>
        <profile name="XV81 Crisis battlesuit" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f6a9-9512-d156-4c20">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a Smart missile system.</characteristic>
            </characteristics>
        </profile>
        <profile name="XV84 Crisis battlesuit" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9f3b-1980-64a5-43da">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a Markerlight and a Target Lock.</characteristic>
            </characteristics>
        </profile>
        <profile name="XV85 Enforcer battlesuit" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4626-ba17-501f-4acd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Wound and a 2+ armor save. Additionally, it may select one more weapon or support system. Can't be combined with other battlesuits.</characteristic>
            </characteristics>
        </profile>
