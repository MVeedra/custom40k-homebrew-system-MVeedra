            </characteristics>
        </profile>
        <profile name="Additional armor" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3542-3867-123a-4dce">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blacksun filter" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="c460-08dc-3eca-40e4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the -1 to hit modifier for cover.</characteristic>
            </characteristics>
        </profile>
        <profile name="Decoy launchers" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="4211-16c1-a4f8-4f08">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores temporary damage results on a roll of 4+.</characteristic>
            </characteristics>
        </profile>
        <profile name="Disruption pod" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="cda1-d8fc-fb8e-4a7e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy units targeting this model from 12" or further away reduce their weapon range by 6".</characteristic>
            </characteristics>
        </profile>
        <profile name="Failsafe detonator" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="4be5-3173-4bf1-48fa">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Activate when the model or its unit are fleeing from melee. Move the unit as normal, while the model stays in place. All remaining models within 6" suffer an automatic hit with Strength 8, AP 0, Damage 1. Remaining units may not pursue the fleeing unit. Remove the model that used the Failsafe detonator afterwards.</characteristic>
            </characteristics>
        </profile>
        <profile name="Flechette discharger" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="6ae1-b6a2-9141-4bd4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy models are automatically wounded with S:4 AP:0 D:1 in melee on a roll of 4+. Roll for each model in direct base contact. This is done at Initiative 10.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jammer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3841-27f0-9710-4a6e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Equipment such as icons or homing beacons do not function within 6" of the model. Additionally, units arriving via deepstrike that land within 12" roll 4D6 instead of 2D6 for scattering.</characteristic>
            </characteristics>
        </profile>
        <profile name="Landing gear" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="f738-1f59-571c-429c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">In every turn where the model does not move, it loses its Anti-Grav rule until the its next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Multi-tracker" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3dbe-d939-b648-4d08">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a +1 to hit modifier, if it is shooting at a target consisting of 6 or more models.</characteristic>
            </characteristics>
        </profile>
        <profile name="Seeker missile" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="b68a-e8f8-a9f7-4b55">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may shoot once per game a Seeker missile with this profile: Range 120", Heavy 1, Strength 8, AP -3, Damage 2, Anti-Air, AT(1). May be taken up to 2 times per model.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Target lock" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="859b-d67c-79e7-4150">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
