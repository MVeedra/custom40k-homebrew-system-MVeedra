        <profile name="Advanced Miniaturization" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="6b9a-bd7e-5554-42a1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Every modell with access to a SUPPORT SYSTEM may pick one additional SUPPORT SYSTEM at the regular cost.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blacklight Markers" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="925d-7e5b-9dfe-4edc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All markerlights of the unit increase their range by 12".</characteristic>
            </characteristics>
        </profile>
        <profile name="Calm under Pressure" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="29c5-72cb-27a2-4930">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit does not suffer the to hit penalty from Defensive Fire.</characteristic>
            </characteristics>
        </profile>
        <profile name="Camouflage Experts" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="e056-2e8d-fb9f-48e2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the benefit of light cover until its first activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Combined Expansion" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="54c5-1dff-2662-49e1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must select a second Legacy. Each model may only select items from one Legacy armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Defenders of the Cause" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="4ab9-fd08-fcc8-49a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit's "Supporting Fire" ability increases its range to 12".</characteristic>
            </characteristics>
        </profile>
        <profile name="Defensive Doctrines" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f7ea-31d0-97d6-453a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit gets charged by an enemy unit, all enemy melee weapons reduce their AP and AT by 1 to a minimum of 0.</characteristic>
            </characteristics>
        </profile>
        <profile name="Disengangement Protocols" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="c54c-d35e-8c15-4316">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Roll 1D6 every time the unit tries to flee from melee combat. One enemy unit in direct base contact suffers the result as automatic wounds with S:4 AP:0 D:1.</characteristic>
            </characteristics>
        </profile>
        <profile name="Evasive Maneuvers" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="07df-0bff-5b7d-4614">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit moved at least 12" away from its current position at the beginning of the battle round, all models gain the "Deflect" ability. Only for Jump Pack units.</characteristic>
            </characteristics>
        </profile>
        <profile name="Fire Caste Marksman" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0369-b88a-333f-46aa">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Deflagrate(5+)" ability with Pulse weapons. Does not apply to "Heavy" weapons.
</characteristic>
            </characteristics>
        </profile>
        <profile name="Fire Saturation" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="60da-9b95-4d26-49c5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Burst weapons gain a +1 bonus to hit rolls against targets within 12".</characteristic>
            </characteristics>
        </profile>
        <profile name="Loyal to the End" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="ea77-3360-b3d7-4c3c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Reliable Weaponry" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="d9c2-2a0a-b420-45a6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one armor penetration or wound roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Signature Evolutionary Adaption" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="5a67-6414-95c9-40bb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select one improvement that must be applied to any $Kroot$ unit:
- Bold: The model gains +1 Leadership.
- Chameleon: The model gains the "Deflect" ability.
- Fast reflexes: The model gains +1 Initiative.
- Ork hybrid: The model gains +1 Strength and +1 Toughness.
- Sixth sense: The model gains a 6+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Strike Swiftly" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="1978-b6a4-cc3c-4d33">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Vanguard" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Swarm Controllers" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="ed7c-eecd-8b34-4575">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Models with access to drones may buy up to three drones in any combination instead of two.</characteristic>
            </characteristics>
        </profile>
        <profile name="Turbo Jets" typeId="equipment_type_id" typeName="Traits" hidden="false" id="f5e3-dfd6-cb24-4141">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +2" Movement. Only for Jump Pack units.</characteristic>
            </characteristics>
        </profile>
