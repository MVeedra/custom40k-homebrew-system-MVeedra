    <profile name="Icon of Nurgle" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="8a98-be39-a28e-0abe">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">A friendly Demon unit arriving within 7&quot; of the bearer via deepstrike does not scatter.</characteristic>
      </characteristics>
    </profile>
    <profile name="Plague Banner" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="58bb-1685-e264-3b0e">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">The unit gains the effects of an Icon of Nurgle. Additionally it gains a bonus of +1 to Leadership and Combat resolutions. As long as the banner bearer is alive, Mission objectives that are held by this unit can not be contested by enemy units.</characteristic>
      </characteristics>
    </profile>
