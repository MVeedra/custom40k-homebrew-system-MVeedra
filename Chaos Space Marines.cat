    <profile name="Combat Drugs" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3805-2ff1-fc62-e470">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Once per battle, select any number of abilities for the model when performing a Charge command:
- +1 Attack
- +1&quot; Charge move
- +1 Strength
- +1 Weapon Skill
- Warded
The effects last until the end of the current battle round. Roll 1D6 for each selected ability. The model suffers one Mortal Wound for each same die roll result.</characteristic>
      </characteristics>
    </profile>
    <profile name="Doom Siren" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1972-80d6-f1b4-789a">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Select one enemy unit within 9&quot; range during your activation that is currently not engaged in melee and roll 3D6. For each 4+ the target suffers one automatic wound with Strength: 4 AP: -1 D: 1; Sunder(2), Suppression.</characteristic>
      </characteristics>
    </profile>
    <profile name="Needle of Desire" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b621-7c45-2705-d3e6">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model can make one additional melee attack per round. Strength: 2 AP: -4 D: 1. Hits wound automatically.</characteristic>
      </characteristics>
    </profile>
    <profile name="Rapturous Standard" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="def8-8499-8124-dbfd">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model and its attached unit gain the &quot;Berserk(5+)&quot; ability. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Steed of Slaanesh" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="24e4-7ada-fbbe-5254">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement, +1 Toughness, +1 Wound, +1 Attack and the &quot;Bike&quot; unit type. Only for infantry.</characteristic>
      </characteristics>
    </profile>
    <profile name="Warp Scream" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3364-41a5-d3d3-56c7">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model and its attached unit always gain the benefit of the &quot;Hold your ground&quot; Defensive reaction.</characteristic>
      </characteristics>
    </profile>
    <profile name="Alacritous" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f9d7-c34d-4946-9d48">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains &quot;Deflect&quot; and &quot;Parry&quot;. Unique.</characteristic>
      </characteristics>
