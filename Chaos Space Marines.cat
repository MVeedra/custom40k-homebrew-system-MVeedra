    </profile>
    <profile name="Nurgle&apos;s Decay" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c6fa-2d15-c11f-cd53">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">All models of the first enemy unit each round activating within 7&quot; must pass a Toughness test or suffer a wound with Strength: 4 AP: 0 D: 1 and the &quot;Sunder(2)&quot; ability.</characteristic>
      </characteristics>
    </profile>
    <profile name="Nurgling Infestation" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="169e-a88d-57a4-e162">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model inflicts 4 automatic hits each activation in close combat. Strength: 2 AP: 0 D:1; Poison(4+).</characteristic>
      </characteristics>
    </profile>
    <profile name="Plague Ammunition" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4167-b257-6d2c-35aa">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">All ranged weapons of the model gain &quot;Poison(3+)&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Plague Outburst" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f30b-e1b6-4e3f-3ed9">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Each time the model casts a psychic power with a 7+, the nearest enemy unit within 21&quot; suffers 3 automatic wound with Strength: 4 AP: 0 D: 1 and the &quot;Sunder(2)&quot; ability.</characteristic>
      </characteristics>
    </profile>
    <profile name="Revoltingly Resilient" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c6c4-7b8e-a5bc-f237">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the &quot;Regeneration(1)&quot; ability.</characteristic>
      </characteristics>
    </profile>
    <profile name="Shamblerot" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0931-39fa-8e38-3c31">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Roll 1D6 during the model&apos;s acitvation, if an enemy vehicle is within 6&quot;:
1 - Nothing happens.
2 to 4 - The vehicle suffers a glancing hit.
5 to 6 - The vehicle suffers a penetrating hit.</characteristic>
      </characteristics>
    </profile>
