      <profiles>
        <profile name="Control Jets" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="db76-43c1-2b6e-7b2f">
          <characteristics>
            <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">The Drop Pod must land at least 6&quot; away from other units (friendly or enemy) and can never stray closer than 1&quot; to another unit, terrain, or the edge of the field. Reduce the deviation only enough to place the drop pod.</characteristic>
          </characteristics>
        </profile>
        <profile name="Drop Pod Assault" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="286d-b765-45e6-da45">
          <characteristics>
            <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">Drop Pods always start the game as reserves and are always set up via Deep strike. Even if the played mission does not allow reinforcements and/or Deep strike!</characteristic>
          </characteristics>
