    <profile name="Chaos Space Marine Bike" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="032f-6799-e727-7213">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement, +1 Toughness, +1 Wound, a Combi-bolter and the unit type &quot;Bike&quot;. Infantry only.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Flight/Jump Pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="259f-eb95-7c9d-d1b2">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement and the unit type &quot;Jump pack&quot;. Infantry only.</characteristic>
      </characteristics>
    </profile>
    <profile name="Baleful Tome" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4f19-b631-3e05-fe5f">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Before the game, select a psychic power from the general psychic powers or the Chaos psychic powers. The model can use this psychic power once per game. Roll 1D6 during the model&apos;s activation. On a 3+, the psychic power is successfully manifested with the required cast value. On a 1, the model suffers a &quot;Perils of the Warp&quot; attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Bionics" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6313-c57e-2d31-e778">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains a 6+ invulnerable save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Chaos Artifact" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b7b4-fdba-574f-68fe">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6&quot; Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army. Can be taken multiple times.</characteristic>
      </characteristics>
    </profile>
    <profile name="Cursed Blade" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2bb4-0985-b647-2195">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains +1 Damage. The point cost for this equipment is the same as for the weapon that it enhances. Can only be used on weapons with D:1. Only for Lieutenants.</characteristic>
      </characteristics>
    </profile>
    <profile name="Icon of Chaos" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7a7d-d905-a294-6d63">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">A friendly Daemon unit arriving within 3&quot; of the bearer via Deep strike does not scatter. If the arriving unit has the same Mark of Chaos as the bearer, it can instead be placed within 6&quot;. The icon must be present on the table at the beginning of the battle round in order to be used.</characteristic>
      </characteristics>
    </profile>
    <profile name="Demagogue" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c808-969f-3943-bb26">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model and its attached unit gain the &quot;Fearless&quot; ability. Only for Dark Apostles. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemon Weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9266-6235-c700-6738">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Select one ability from the &quot;Daemon weapons&quot; section and apply it to one weapon of the model. Can&apos;t be combined with &quot;Greater Daemon weapon&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Armour" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1667-fd61-c517-3e76">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains a 2+ save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Aura" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="df37-b6c3-3d37-09a5">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the &quot;Daemon&quot; ability (Note: a 5+ invulnerability save).</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Essence" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e45e-5b85-57ca-2819">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Wound.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Mutation" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b3c7-caaa-fa65-23e7">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Resilience" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8894-5b0e-7e4d-62ff">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Stature" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bc93-4ade-0699-5864">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the &quot;Monstrous Infantry&quot; unit type and the &quot;Deepstrike&quot; ability.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Strength" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="803d-125d-619a-c6ee">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Strength.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Swiftness" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="3894-bf80-2d7d-8da2">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the ability &quot;Move Through Cover&quot; and may reroll advance rolls.</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemonic Venom" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bdb6-e762-1564-30d6">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">All melee attacks of the model gain &quot;Poison(4+)&quot;</characteristic>
      </characteristics>
    </profile>
    <profile name="Familiar" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8a69-09e7-9b92-bd51">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may sacrifice the Familiar to reroll a psychic power manifestation test. While it is alive, the model gains +1 Initiative. Only for Sorcerers.</characteristic>
      </characteristics>
    </profile>
    <profile name="Greater Daemon Weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c8c1-c181-e551-805b">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Select two abilities from the &quot;Daemon weapons&quot; section and apply it to one weapon of the model. Can&apos;t be combined with &quot;Daemon weapon&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Instrument of Chaos" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7749-d650-627d-1a7e">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The unit gains a bonus of +1 to Combat resolutions.</characteristic>
      </characteristics>
    </profile>
    <profile name="Marksman Honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="df76-8692-d79a-dc40">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic skill.</characteristic>
      </characteristics>
    </profile>
    <profile name="Master-Crafted Weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2880-56d7-2d22-d7fc">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may re-roll one to hit roll per activation. Must be purchased for each weapon seperately.</characteristic>
      </characteristics>
    </profile>
    <profile name="Psychic Training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7bc8-f071-e059-4a92">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
      </characteristics>
    </profile>
    <profile name="Spikey Bits" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dc8e-e93b-317d-e406">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may re-roll one to wound roll in melee per activation.</characteristic>
      </characteristics>
    </profile>
    <profile name="Swordsman Honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="4c9b-c882-b2e1-241d">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
      </characteristics>
    </profile>
    <profile name="Teleport Homing Beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="19ff-30ad-de9e-414d">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3&quot; of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
      </characteristics>
    </profile>
    <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6817-4b10-a402-9043">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the ability &quot;Terrifying(-1)&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Blasphemous Rune" typeId="57f5-93cf-6d5d-4dca" typeName="Vehicle_Equipment" hidden="false" id="727c-8b6c-fb71-22ef">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may attempt to deny one psychic power per battle round.</characteristic>
      </characteristics>
    </profile>
    <profile name="Dirge Caster" typeId="57f5-93cf-6d5d-4dca" typeName="Vehicle_Equipment" hidden="false" id="5b00-18f9-c6e4-b9c3">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Friendly models within 6&quot; range gain the &quot;Fearless&quot; ability.</characteristic>
      </characteristics>
    </profile>
    <profile name="Living Vehicle" typeId="57f5-93cf-6d5d-4dca" typeName="Vehicle_Equipment" hidden="false" id="e98c-c577-e7ff-bcf2">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the &quot;Living vehicle&quot; weapon and improves its WS value to 4+, unless it is already better.</characteristic>
      </characteristics>
    </profile>
    <profile name="Living Vehicle" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="05f9-6b3e-dee5-367c">
