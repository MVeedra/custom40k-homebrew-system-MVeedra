      <modifiers>
        <modifier type="increment" value="1" field="db0e-8327-6902-708d">
          <comment>You may not select more Poxwalker units than Plague Marine units.</comment>
          <repeats>
            <repeat value="1" repeats="1" field="selections" scope="force" childId="9d66-a583-b371-49cd" shared="true" roundUp="false" includeChildSelections="true"/>
          </repeats>
        </modifier>
        <modifier type="add" value="You may not select more Poxwalker units than Plague Marine units." field="error" affects="unit">
          <conditionGroups>
            <conditionGroup type="or">
              <conditionGroups>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="1" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="2" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="3" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="4" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="5" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="6" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="2" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="1" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="3" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="1" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="4" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="1" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="5" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="1" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="3" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="2" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="equalTo" value="4" field="selections" scope="force" childId="d87a-e5cc-dbec-86b8" shared="true" includeChildSelections="true" includeChildForces="true"/>
                    <condition type="equalTo" value="2" field="selections" scope="force" childId="8506-3054-589c-d37b" shared="true" includeChildSelections="true" includeChildForces="true"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </conditionGroup>
          </conditionGroups>
          <comment>Since there is no proper logic for &quot;If Plague Marines in Force &gt; Poxwalkers in Force&quot; I had to add every possible Marine and Poxwalker combination that would make the error message appear. Not elegant but it works.</comment>
        </modifier>
        <modifier type="set" value="0" field="db0e-8327-6902-708d">
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="b1dc-1148-1c1b-9510" shared="true" includeChildSelections="true"/>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1309-8c33-70e6-2d10" shared="true" includeChildSelections="true"/>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="220a-ad83-513c-4a0f" shared="true" includeChildSelections="true"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
        </modifier>
