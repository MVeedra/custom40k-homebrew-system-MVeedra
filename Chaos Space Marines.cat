        <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">Flurry(3)</characteristic>
      </characteristics>
    </profile>
    <profile name="Mutated Hull" typeId="57f5-93cf-6d5d-4dca" typeName="Vehicle_Equipment" hidden="false" id="bda8-2c31-48d3-464b">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model increases its Armor Value (AV) on one side by +1, to a maximum of 14.</characteristic>
      </characteristics>
    </profile>
    <profile name="Dark" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f01f-e5e4-261e-9bc9">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The weapon gains +1 Strength. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Kai" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a1b6-dd21-8b6a-1d8b">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains the &quot;Kai gun&quot; ranged weapon. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Unstoppable" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6053-920d-59cd-50d3">
