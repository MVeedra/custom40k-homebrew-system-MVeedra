    <profile name="Arcane Compulsion" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f82d-c0e6-7713-76d2">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Reduce enemy Charge movements targeting the bearer and their attached unit by 2&quot;.</characteristic>
      </characteristics>
    </profile>
    <profile name="Astral Grimoire" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="adf9-607a-49cb-9be0">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Select one friendly unit within 12&quot; during the Reinforcement phase. For the remainder of the battle round the unit got a Movement value of 12&quot; and gains the &quot;Anti-Grav&quot; ability. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Athenaean Scroll" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b4c0-04f2-dfbf-3903">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">If a test to manifest a psychic power rolls any doubles, the power is manifested and can&apos;t be denied (Note: a double 1 still perils). If a test to deny a psychic power rolls any doubles, the power is denied regardless of the actual result. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Bringer of Change" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e672-7116-30f9-da6c">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The player may demand a single die to be re-rolled each round, regardless from which player. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Cult Initiate" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0282-07aa-cbaf-2f3b">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may exchange one psychic power it knows with one from the list of &quot;Cult Powers&quot;. All Cult Powers within an army must be the same, if any is chosen. Only for models from this Codex.</characteristic>
      </characteristics>
    </profile>
    <profile name="Helm of the Third Eye" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f481-60e2-ed9a-6227">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model and any attached unit ignore any or all to hit modifiers, including for Defensive Fire. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Hourglass of Manoth" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6f7d-c00a-e807-f859">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Roll a die the first time the model is eliminated: 
1,2 - Remove the model.
3,4 - Set it back up with 1 wound. 
5,6 - Set it up again with 2 wounds. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Talisman of Tzeentch" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1be9-3851-538c-58bd">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Can be activated once per game to grant friendly and enemy psykers a +1 bonus to manifestation rolls until the next battle round. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Weaver of Magics" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="9911-b810-f8af-7350">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model may give itself one of these bonuses each round:
- Change one &quot;Normal&quot; psychic power to &quot;Basic&quot;.
- Change one &quot;Complex&quot; psychic power to &quot;Normal&quot;.
- Get a +1 bonus to manifest one psychic power.
- Get a +1 bonus to deny one psychic power.
Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Disc of Tzeentch" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6e8f-5ed6-1666-42e6">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +6&quot; Movement, +1 Wound, +1 Attack and the &quot;Jetbike&quot; unit type. Only for infantry.</characteristic>
      </characteristics>
    </profile>
    <profile name="Magical" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5810-9c51-0ace-aae6">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 to manifest and deny psychic powers. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Warping" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0983-243a-46d4-85db">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The weapon gains a ranged profile with 18&quot; range. It can shoot during each activation as often as the model can attack. Can&apos;t be used on a weapon with the &quot;Slow&quot; ability. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Weaving" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8973-4163-bc5d-d317">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Once per battle round, the model and its attached unit can change the result of a single die roll of themselves or an enemy unit they are attacking. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Cursed Crozius" typeId="77f2-c286-4a8e-85d6" typeName="Melee Weapons" hidden="false" id="4355-6e45-0039-3aed">
      <characteristics>
        <characteristic name="Range" typeId="17a8-c6d1-4902-3240">-</characteristic>
        <characteristic name="Type" typeId="85b8-b86f-84a1-6a8a">Melee</characteristic>
        <characteristic name="S" typeId="dfe1-ab2e-bf82-b051">+2</characteristic>
        <characteristic name="AP" typeId="5769-5be9-c3dd-1b76">-3</characteristic>
        <characteristic name="D" typeId="40a0-b76f-918f-50a5">2</characteristic>
        <characteristic name="Keywords" typeId="a78e-ed35-c409-5cda">Gruesome. Only for Dark Apostles</characteristic>
      </characteristics>
    </profile>
    <profile name="Baleful Icon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8541-664f-c9dc-93ea">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">Any unit selecting this model or its attached unit as a charge target must resolve a test for dangerous terrain.</characteristic>
      </characteristics>
    </profile>
    <profile name="Crown of the Blasphemer" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1157-d1a1-31cd-b821">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">If the model attempts to use a prayer, the roll is automatically successful.</characteristic>
      </characteristics>
    </profile>
    <profile name="Malefic Tome" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="bf9f-acfc-3ad0-c0ee">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">If the model attempts to use an infernal pact, the roll is automatically successful.</characteristic>
      </characteristics>
    </profile>
    <profile name="The Scripts of Erebus" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="74dc-c6b8-823a-62f4">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">If the model attempts to use a psychic power, the roll is automatically successful with the minimum cast value necessary. The model may choose to use the effect of this item.</characteristic>
      </characteristics>
    </profile>
    <profile name="The Skull of Monarchs" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="7b75-ee89-bdd4-05ee">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model and its attached unit receive a +5 bonus to all combat results and the &quot;Fearless&quot; ability. Unique.</characteristic>
      </characteristics>
    </profile>
    <profile name="Tzaangor" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="ab06-d3e8-47d9-98c2">
      <characteristics>
        <characteristic name="M" typeId="2734-8af3-55f8-d225">6&quot;</characteristic>
        <characteristic name="WS" typeId="b8b1-cb7e-422b-9e59">4+</characteristic>
