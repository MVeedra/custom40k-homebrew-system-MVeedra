    <profile name="Icon of Chaos" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="9ad7-998e-d867-e997">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">A friendly Demon unit arriving within 3&quot; of the bearer via Deep strike does not scatter. If the arriving unit has the same Mark of Chaos as the bearer, it can instead be placed within 6&quot;. The icon must be present on the table at the beginning of the battle round in order to be used.</characteristic>
      </characteristics>
    </profile>
    <profile name="Instrument of Chaos" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Abilities" hidden="false" id="8e7b-e77e-4fc2-650f">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">The unit gains a bonus of +1 to Combat resolutions.</characteristic>
      </characteristics>
    </profile>
