    <profile name="Cataphractii Armour" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="93e3-32d8-8bbb-199d">
      <characteristics>
        <characteristic name="Description" typeId="0207-88db-7926-4ba6">The model gains +1 Toughness, +1 Attack, a 2+ armor save, a 4+ invulnerable save and the abilities &quot;Deep strike&quot;, &quot;Massive(1)&quot; and &quot;Unyielding&quot;. Only for infantry.</characteristic>
