        <profile name="Heavy stubber" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="06f7-30bc-c85d-4ca0">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains an additional Heavy stubber.  Range 36" Type Heavy 3 S 4 AP 0 D 1 Suppression.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hunter-killer missile" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="ae60-ab75-4889-4ebf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may shoot once per game a Hunter-killer missile with this profile Range 120", Heavy 1, Strength 8, AP -3, Damage 2, AT(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Improved targeting" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="34d4-53c0-250c-47a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jammer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3841-27f0-9710-4a6e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Equipment such as icons or homing beacons do not function within 6" of the model. Additionally, units arriving via deepstrike that land within 12" roll 4D6 instead of 2D6 for scattering.</characteristic>
            </characteristics>
        </profile>
        <profile name="Macharius cross" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="d4c0-f744-495d-4332">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can issue one more order per battle round than it normally could. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity seal" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="1efa-b2f1-72cd-46f2">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy Psykers suffer -1 to their psychic tests when the psychic power of this model or the attached unit targets them directly.</characteristic>
            </characteristics>
        </profile>
        <profile name="Regimental artefact" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="26a4-ed6b-503a-4a52">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Seasoned officer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="de7a-3150-b7b0-4b11">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A single unit can receive up to two simultaneous orders per turn if it is activated within range of an officer.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Storm bolter" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="5a28-61a6-72c2-4470">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains an additional Storm bolter.  Range 24" Type Rapid Fire 2 3 S 4 AP -1 D 1.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Vox" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="8e0a-b974-fab7-472b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If an officer is a passenger in the vehicle, he counts as being equipped with a personal vox. The vehicle itself can receive orders anywhere on the battlefield and, if it is a Tank Commander, can issue orders.</characteristic>
            </characteristics>
        </profile>
        <profile name="Leman Russ Commissar" typeId="59b4-be0a-1831-66da" typeName="Vehicle" hidden="false" id="9c42-344b-12bc-4ca6">
