        <profile name="Aquila Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b37e-5d3b-dad7-4608">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Bionics" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e785-c2c1-a8b4-43cc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 6+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Crimson medal" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c0cc-55f9-63b7-4218">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Once per game, if the model would be killed, it automatically ignores the wound.</characteristic>
            </characteristics>
        </profile>
        <profile name="Digital weapons" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8402-8368-65de-4ff8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can make one additional melee attack per round. S:2 AP:-4 D:1. Hits automatically wound.</characteristic>
            </characteristics>
        </profile>
        <profile name="Familiar" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e3f5-4da2-1972-4117">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 initiative and can sacrifice the familiar to reattempt a psychic test. Only for Primaris Psykers.</characteristic>
            </characteristics>
        </profile>
        <profile name="Gamma psyker" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c19b-6292-d290-4fd7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can manifest 1 additional psychic power per round. Only for Primaris Psykers. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Grav-chute" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="316a-7cea-d049-4eb7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Deep strike" ability. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Honorifica Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="24e1-4a89-7063-40a4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Attack and +1 Leadership value. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Macharius cross" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6ed6-2dc5-53ba-4a00">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can issue one more order per battle round than it normally could. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic Skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="07d5-ce8f-42ff-4940">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ armor save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can reroll one hit roll with this weapon per round. Must be purchased separately for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Mechanical steed" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="add4-239f-2cbc-464c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" Movement, +1 Strength +1 Toughness, +1 Wound, +1 Attack and the type "Bike". For infantry only.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Personal vox" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="abed-8145-dfc6-4faa">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Units equipped with a vox always count as being within range of this officer.</characteristic>
            </characteristics>
        </profile>
        <profile name="Plate armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6770-354e-d502-4933">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ armor save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Psychic training" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="1e41-f014-356d-4fec">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional psychic power from one of their chosen psychic disciplines. If it already knows all powers from each discipline, it may instead learn one power from a new discipline it has access to. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity seal" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="37db-7dd8-dcf3-4dd5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy Psykers suffer -1 to their psychic tests when the psychic power of this model or the attached unit targets them directly.</characteristic>
            </characteristics>
        </profile>
        <profile name="Refractor field" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c8d0-9b2b-446a-471f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 5+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Regimental relic" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5aa9-cd2f-18a8-4c5a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Scanner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="18ca-e659-ea0d-4903">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit has not already activated this turn, it may immediately use up its order and fire at an enemy unit within 18" that is deployed as reinforcement as if it had been given the "Stand & Shoot" order. The attack resolves after the enemy unit has been deployed and before it takes another action.</characteristic>
            </characteristics>
        </profile>
        <profile name="Seasoned officer" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2320-ae40-3ea2-4816">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A single unit can receive up to two simultaneous orders per turn if it is activated within range of an officer.</characteristic>
            </characteristics>
        </profile>
        <profile name="Special energy cells" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2ba4-fef3-faae-4f93">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Each laser weapon of the model receives an additional -1 AP, +1 Damage and "Overheating".</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
        <profile name="Vox" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="d3e5-5dca-f4b3-4310">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">As long as the model is alive, it always counts as being within range of an officer, as long as at least one officer is on the field and has a (personal) vox.</characteristic>
            </characteristics>
        </profile>
        <profile name="Abhuman Auxiliaries" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="1206-6e37-6dbc-4c3a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Select one improvement that can be applied to any creature unit (except Halflings and Ogryns)
- Afriel Strain The unit gains the "They Shall Know No Fear" ability (see Space Marines).
- Beasts The unit gains the "Furious Charge" ability.
- Gland Warriors The unit gains +1 Strength. During every activation it needs to pass a Dangerous Terrain test.
- Nightsiders The unit gains the "Acute Senses" ability.
- Slave Levies The unit gains the "Unyielding" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Bionic Improvement" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="2d07-50eb-456f-4f07">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Creature models gain a 6+ invulnerability save. Only for creature models that do not already have an invulnerability save from their datasheet or Armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Born Soldiers" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f3c6-a34b-829a-439f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit may re-roll ranged to hit rolls of 1 with Assault, Pistol and Rapid Fire weapons.</characteristic>
            </characteristics>
        </profile>
        <profile name="Cameleolin" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="4ce2-07e0-b9e2-4a97">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains a cumulative +1 bonus to armor save rolls while benefitting from cover.</characteristic>
            </characteristics>
        </profile>
        <profile name="Close Combat Specialists" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0d41-102e-5418-4c1f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Each model may swap their Lasgun for a Las pistol and a Close combat weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Combined Regiments" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="de1c-fc26-4873-4c32">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must select a second Legacy. Each model may only select items from one Legacy armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Disciplined Shooters" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="193f-b3a0-f26b-48e9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit does not suffer the to hit penalty from Defensive Fire.</characteristic>
            </characteristics>
        </profile>
        <profile name="Fanatism" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="f5b2-aa9a-727b-473b">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Blind Rage" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Hardened Fighters" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="d415-62d9-9991-405e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Heavy Infantry" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="d947-94e0-2719-420a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains Krak grenades and Plate armor. Can't be combined with "Jungle Fighters".</characteristic>
            </characteristics>
        </profile>
        <profile name="Heirloom Weapons" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="d83e-97cf-b8b8-44d3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can reroll one armor penetration or wound roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Iron Discipline" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0c07-8fdd-0a3f-42eb">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jury-rigged repairs" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="bcda-f9fe-35b0-48dc">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Vehicles can use the "Blessing of the Omnissiah" ability (See Engineseer) on themselves, but only for repairs.</characteristic>
            </characteristics>
        </profile>
        <profile name="Las Fusilade" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="d28d-2972-2c18-46ee">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Deflagrate(5+)" ability with Las weapons. Does not apply to "Heavy" weapons.</characteristic>
            </characteristics>
        </profile>
        <profile name="Rapid Assault" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="35a0-936f-e64b-44e8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can fire Assault weapons, Grenades and Pistols without a to hit penalty with Advance and Charge orders.</characteristic>
            </characteristics>
        </profile>
        <profile name="Shock Troops" typeId="equipment_type_id" typeName="Traits" hidden="false" id="7e39-1140-a7e9-4ea6">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Deep strike" ability.</characteristic>
            </characteristics>
        </profile>
        <profile name="Lord Commissar" typeId="a016-3bd5-58b1-188d" typeName="Unit" hidden="false" id="49bd-641a-1cb4-4ea5">
            <characteristics>
                <characteristic name="M" typeId="2734-8af3-55f8-d225">6"&quot;</characteristic>
