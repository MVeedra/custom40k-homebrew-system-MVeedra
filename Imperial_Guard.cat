                <categoryLink name="Transports" hidden="false" id="df97-8d06-116a-4169" targetId="8046-e26a-aa36-3308" primary="true"/>
            </categoryLinks>
        </entryLink>
        <entryLink import="true" name="Taurox" hidden="false" id="bab4-6e5e-39b4-43ef" type="selectionEntry" targetId="9102-1d78-a8cf-48bb">
            <categoryLinks>
                <categoryLink name="Transports" hidden="false" id="c0d5-ca4e-0f28-4ead" targetId="8046-e26a-aa36-3308" primary="true"/>
            </categoryLinks>
        </entryLink>
        <entryLink import="true" name="Valkyrie" hidden="false" id="a77d-7572-62d6-460e" type="selectionEntry" targetId="6dd7-640c-2bdc-45cb">
            <categoryLinks>
                <categoryLink name="Transports" hidden="false" id="5656-884e-b5ee-4ad7" targetId="8046-e26a-aa36-3308" primary="true"/>
            </categoryLinks>
        </entryLink>
    </entryLinks>
    <sharedRules>
        <rule name="Orders" id="7fcb-a3f4-7678-430c" hidden="false">
            <description>Each officer issues the army one or more orders, which can be selected or exchanged in the Reinforcement phase of each turn. Each of the Imperial Guard's own units (= units selected from this codex) can use one of the previously selected orders at the specified time, as long as it is within 12" of an officer at the start of its activation. An order is not consumed and any number of units can use the same order in a turn. Unless otherwise stated, the effect of the order lasts until the end of the unit's activation. Each unit can only benefit from a single order per turn. An officer knows all orders from the list of orders.</description>
        </rule>
        <rule name="Weapon team crews" id="e95d-36b0-624d-4fae" hidden="false">
            <description>Some units have the option to have their models form a "Heavy weapons team". These models use the "Heavy Weapon Squad" profile.</description>
        </rule>
        <rule name="Officer" id="4855-f3f0-9188-4cfe" hidden="false">
            <description>A Primaris Psyker issues 1 order.</description>
        </rule>
        <rule name="Colonel" id="3b3a-cb00-b2c8-4fed" hidden="false">
            <description>A Colonel issues 1 additional order.</description>
        </rule>
        <rule name="Lumbering Behemoth" id="890a-07a5-05ae-41ab" hidden="false">
            <description>The model may not receive an "Advance" order. Additionally, it always counts as having received a "Stand & Shoot" order when shooting its weapons.</description>
        </rule>
        <rule name="Aura of Discipline" id="0ca1-4de6-e6e0-438d" hidden="false">
            <description>Friendly units in a 12" radius use the Lord Commissar's Leadership value.</description>
        </rule>
        <rule name="Statutory Execution" id="8da2-9980-18e8-4501" hidden="false">
            <description>Each time time a friendly unit within a 6" radius fails a Leadership test, a model is removed from the unit and the Leadership test is repeated without any penalty.</description>
        </rule>
        <rule name="Chain of command" id="0a6f-1517-2fc5-4e50" hidden="false">
            <description>Units that activate within 12" of the Lieutenant can receive orders as if an officer were in range.</description>
        </rule>
        <rule name="Sniper" id="34f3-b13b-c76e-4a7e" hidden="false">
            <description>Models with a sniper rifle receive a +1 bonus to their BS value.</description>
        </rule>
        <rule name="It's for your own good" id="42d9-9c8a-a049-4d5c" hidden="false">
            <description>Instead of suffering a Perils of the Warp attack, one model is immediately slain if a Commissar is within 6".</description>
        </rule>
        <rule name="Psyker" id="943c-18af-a1bb-44ed" hidden="false">
            <description>The unit can cast 1 power and deny 1 power per battle round. It knows Smite and one power from a chosen discipline per Sanctioned Psyker model.</description>
        </rule>
        <rule name="Send the next wave!" id="4a1e-27f7-fa6e-4f5a" hidden="false">
            <description>If the unit is below half its target strength or is destroyed, it can be removed from the field once per game at the end of the battle round and automatically reappears as a reserve at full target strength in the next battle round.</description>
        </rule>
        <rule name="Hive Scum" id="3868-7200-fa2a-4170" hidden="false">
            <description>This unit may not make use of any order.</description>
        </rule>
        <rule name="Cawdor" id="c419-48b6-a8bc-4278" hidden="false">
            <description>The model gains +1 Leadership.</description>
        </rule>
        <rule name="Delaque" id="c17d-a73a-6391-4d19" hidden="false">
            <description>The model gains "Infiltrator".</description>
        </rule>
        <rule name="Escher" id="6ab7-5b97-968a-4d86" hidden="false">
            <description>All weapons of the model gain "Poison(5+)".</description>
        </rule>
        <rule name="Goliath" id="6557-d47c-475d-4b0b" hidden="false">
            <description>The model gains +1 Strength and +1 Toughness.</description>
        </rule>
        <rule name="Orlock" id="1dea-435e-dd1a-466a" hidden="false">
            <description>Another model may receive a Special weapon.</description>
        </rule>
        <rule name="Van Saar" id="074c-d8e3-768f-4857" hidden="false">
            <description>The model gains a 5+ armour save.</description>
        </rule>
        <rule name="Combined squads" id="54d8-9292-7221-4df4" hidden="false">
            <description>During deployment, Infantry squads can be combined with any number of other Infantry squads. They act as a single unit for the rest of the game.</description>
        </rule>
        <rule name="Explosive Collars" id="4d9f-aadc-9a25-4ca0" hidden="false">
            <description>Each time this unit fails a Leadership test, a model is removed from the unit and the Leadership test is repeated without any penalty.</description>
        </rule>
        <rule name="Last Chancers" id="1570-bc3b-0804-4362" hidden="false">
            <description>This unit may not make use of any order.</description>
        </rule>
        <rule name="Gunslingers" id="9bb2-42a5-df14-4b1c" hidden="false">
            <description>The model gains a Lasgun.</description>
        </rule>
        <rule name="Knife Fighters" id="0860-ffdf-ba50-45c7" hidden="false">
            <description>The model gains a Close combat weapon and a Las pistol.</description>
        </rule>
        <rule name="Advisor" id="400a-74e8-a20d-4b3e" hidden="false">
            <description>For each HQ selection, one Ogry Bodyguard may be selected that does not occupy an Elite slot.</description>
        </rule>
        <rule name="Brute shield" id="bb2c-ebaa-53ce-4141" hidden="false">
            <description>The model gains the abilities "Deflect" and "Parry".</description>
        </rule>
        <rule name="Plate shield" id="11b1-ce2f-b01e-4fcf" hidden="false">
            <description>The model gains +2 to armor rolls.</description>
        </rule>
        <rule name="Banner" id="0e32-9c70-0d43-4479" hidden="false">
            <description>The unit gains a bonus of +1 to Leadership.</description>
        </rule>
        <rule name="Medical bag" id="5a2f-e7c8-ac4c-4eec" hidden="false">
            <description>Once per turn, the damage of a wound against the model or attached unit can be reduced by 1. The ability must be declared after armor and invulnerability saves. Does not work against weapons with a strength of 8 or above.</description>
        </rule>
        <rule name="Crusade" id="fdd3-9069-80a1-46cc" hidden="false">
            <description>The model and its attached unit gain the "Frenzy(1")" ability and roll 2D6 (pick highest) for the extra movement with an Advance order.</description>
        </rule>
        <rule name="Blessing of the Omnissiah" id="daee-0a90-e491-4172" hidden="false">
            <description>At the end of its move, the model may attempt to repair a vehicle within 6". On a 4+, one "Weapon destroyed" or "Engine damage" result is removed from the vehicle, or 1 hull point is restored. Alternatively, a vehicle within 6" can reroll a hit roll and a wound or armor penetration roll.</description>
        </rule>
        <rule name="Servitor" id="6ece-b1d2-81a4-465d" hidden="false">
            <description>As long as the Engineseer is alive, Servitors get +1 to hit rolls.</description>
        </rule>
        <rule name="Priority bombardment" id="9ebe-50bf-ea26-45b4" hidden="false">
            <description>Only one artillery strike can be used per turn.</description>
        </rule>
        <rule name="Logistics Coordination" id="286d-3cd5-5926-47f1" hidden="false">
            <description>Add +1 to rolls during the Initiative and Reinfocement phase as long as there is at least one Officer of the Fleet on the field.</description>
        </rule>
        <rule name="Protect the little 'unz" id="f48d-925a-97fa-4262" hidden="false">
            <description>The defensive profile for this model always takes precedent in any unit it is attached to, even if it is not part of the majority. This means all wounds are first assigned to this model as well.</description>
        </rule>
        <rule name="Faithful" id="1000-8ad3-5d76-48bb" hidden="false">
            <description>Can recite 1 hymn per battle round. A hymn is successfully recited on a roll of 3+. Knows all Hymns of Battle.</description>
        </rule>
        <rule name="Rosarius" id="d3a6-72cf-8f05-45c8" hidden="false">
            <description>This model has a 4+ invulnerability save.</description>
        </rule>
        <rule name="Battlemutt" id="87ae-5e97-a8fe-4f00" hidden="false">
            <description>Once per game, the unit can perform a Defensive reaction, even if it has already used its order in that combat round.</description>
        </rule>
        <rule name="Psionic Choir" id="ef8e-4075-d406-4255" hidden="false">
            <description>For every 3 models, the unit can manifest and banish +1 psychic power per round. As long as it consists of at least 3 models, it receives +1 on rolls to manifest psychic powers.</description>
        </rule>
        <rule name="Sentinel chainsaw" id="ef19-aed1-77d1-469c" hidden="false">
            <description>Das Modell erhält zusätzlich +2 auf sein KG und +2 auf A.</description>
        </rule>
        <rule name="Remote mine" id="fe83-813a-fdcb-43cf" hidden="false">
            <description>During activation, the unit can release a Remote mine. Roll 1D6. On a 2+, the Remote mine hits one enemy unit within 18".</description>
        </rule>
        <rule name="Explosive ammunition container" id="668b-31a0-18c4-49a3" hidden="false">
            <description>If the Hellhound is destroyed, it explodes automatically. The explosion range is 6" and the automatic hit is handled with the profile of the turret weapon.</description>
        </rule>
        <rule name="Charge" id="486e-ec7a-4453-4fc1" hidden="false">
            <description>The charge profile of each lance can only be used if the unit has executed a "Charge" command during its activation.</description>
        </rule>
        <rule name="Attilan-Rider" id="875b-f5be-a6f7-4488" hidden="false">
            <description>The model gains +1 Strength.</description>
        </rule>
        <rule name="Chem-Rider" id="0154-7fb5-6ab2-4494" hidden="false">
            <description>The model gains "Berserk(5+)".</description>
        </rule>
        <rule name="Death-Rider" id="5873-5497-dced-45af" hidden="false">
            <description>The model gains +1 Attack.</description>
        </rule>
        <rule name="Mukaali-Rider" id="06b1-fd2b-48b0-403b" hidden="false">
            <description>The model gains +1 Toughness, +1 Wound and -1 Initiative.</description>
        </rule>
        <rule name="The hour is nigh" id="2e94-9548-3437-4670" hidden="false">
            <description>The Deathstrike missile can only be fired once per game. Roll a D6 each battle round during the unit's activation. On 6+ the missile is ready and can be fired. Add +1 to the roll for each past battle round.</description>
        </rule>
        <rule name="Support Weapons crew" id="ed8d-141a-3052-4527" hidden="false">
            <description>Every instance of damage can only ever cause 1 wound loss. Attacks with the "Barrage" or "Explosive" ability cause one hit for each Wound remaining on the model.</description>
        </rule>
        <rule name="Smoke shells" id="d1ec-33f7-c238-4c66" hidden="false">
            <description>Smoke shells can only be fired at friendly units. Smoke shells do not require a hit roll. Instead of dealing damage, the friendly unit gains the benefit of obscuring terrain until the Gryphon's next activation.</description>
        </rule>
        <rule name="Infernus" id="73cb-bb77-551b-4d39" hidden="false">
            <description>If an Inferno gun is selected as the turret weapon, no other rump weapon may be taken.</description>
        </rule>
        <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
            <description>This model has a transport capacity of 12 infantry models.</description>
        </rule>
    </sharedRules>
    <sharedSelectionEntryGroups>
    </sharedSelectionEntryGroups>
    <categoryEntries>
    </categoryEntries>
    <catalogueLinks>
    </catalogueLinks>
</catalogue>