        <profile name="Additional armor" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3542-3867-123a-4dce">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model ignores the first temporary vehicle damage each round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blessed ammunition" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="0dae-1eef-598c-4103">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One bolt weapon of the model ignores cover. Must be purchased separately for each bolt weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Holy icon" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="99ec-f1d7-bbfc-4d2c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Friendly units within a 6" radius receive +1 to their Leadership value.</characteristic>
            </characteristics>
        </profile>
        <profile name="Holy promethium" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="bf62-762a-2dbb-4cd7">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The Immolator's Twin heavy flamer gains +1 Strength and "Suppression".</characteristic>
            </characteristics>
        </profile>
        <profile name="Hunter-killer missile" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="ae60-ab75-4889-4ebf">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model may shoot once per game a Hunter-killer missile with this profile: Range 120", Heavy 1, Strength 8, AP -3, Damage 2, AT(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Improved targeting" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="34d4-53c0-250c-47a8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model does not have to declare its ranged weapons at all targets before firing, and can choose a new target for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jammer" typeId="766f-e609-4aa9-47e8" typeName="Vehicle_equipment" hidden="false" id="3841-27f0-9710-4a6e">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Equipment such as icons or homing beacons do not function within 6" of the model. Additionally, units arriving via deepstrike that land within 12" roll 4D6 instead of 2D6 for scattering.</characteristic>
            </characteristics>
        </profile>
        <profile name="Smoke Launcher" typeId="equipment_type_id" typeName="Vehicle_equipment" hidden="false" id="6bdd-671f-77c2-4924">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can use its Smoke Launcher once per game:
- During normal activation, instead of firing weapons.
- If it has not yet carried out its order this round and is targeted by an enemy unit. The order is consumed by doing so.
Enemy units can only deal glancing hits with ranged attacks until the next activation.</characteristic>
            </characteristics>
        </profile>
