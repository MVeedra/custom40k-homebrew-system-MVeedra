        <profile name="Anointment" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="89ba-b9b9-6d98-4747">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The models generates +1 Faith Point for the army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Aquila Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b37e-5d3b-dad7-4608">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Armorium cherub" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="10d3-1978-3ef3-422f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model or the attached unit can fire a weapon twice during one activation. Each unit can benefit from this effect only once per round. Ammo(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Auspex scanner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="478d-93b5-9e5b-4bf4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit has not already activated this turn, it may immediately use up its order and fire at an enemy unit within 18" that is deployed as reinforcement as if it had been given the "Stand & Shoot" order. The attack resolves after the enemy unit has been deployed and before it takes another action.                                                                                        </characteristic>
            </characteristics>
        </profile>
        <profile name="Blessed ammunition" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0f41-a9c8-2448-4008">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One bolt weapon of the model ignores cover. Must be purchased separately for each bolt weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blessing" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f721-bb57-6dfe-4e53">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional Hymn of Battle. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Book of St. Lucius" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b691-41f5-a890-45d4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All friendly units within 6" always use their unmodified Leadership value for tests. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Digital weapons" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8402-8368-65de-4ff8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can make one additional melee attack per round. S:2 AP:-4 D:1. Hits automatically wound.</characteristic>
            </characteristics>
        </profile>
        <profile name="Dominion" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a131-6ed2-6e56-4939">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Vanguard" ability. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Holy weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8a7f-28ce-1322-4e09">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One melee weapon of the model gains +1 Damage. The point cost for this equipment is the same as for the weapon that it enhances. Can only be used on weapons with D:1. Only for Palantines.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jump pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="40a2-8813-f362-4d71">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement and the "Jump pack" rule. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Ballistic Skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="07d5-ce8f-42ff-4940">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 2+ armor save. Not combinable with other armors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Master-crafted weapon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="067c-4ecf-e552-45f9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can reroll one hit roll with this weapon per round. Must be purchased separately for each weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Order banner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f37c-2373-9fc9-4ef9">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains a bonus of +1 to Leadership and Combat resolutions. As long as the banner bearer is alive, Mission objectives that are held by this unit can not be contested by enemy units. Additionally, all models in the unot gain +1 Attack. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Plate armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="6770-354e-d502-4933">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ armor save. Not combinable with other armors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Power armor" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="ec68-1ce8-224b-49d3">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 3+ armor save. Not combinable with other armors.</characteristic>
            </characteristics>
        </profile>
        <profile name="Praesidium Protectiva" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="e6ee-0ebb-727d-4e3d">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains a 4+ invulnerability save.</characteristic>
            </characteristics>
        </profile>
        <profile name="Purity seal" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="37db-7dd8-dcf3-4dd5">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Enemy Psykers suffer -1 to their psychic tests when the psychic power of this model or the attached unit targets them directly.</characteristic>
            </characteristics>
        </profile>
        <profile name="Relic of the order" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="c03a-bd07-a454-471c">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One weapon of the model gains one of the following:
- Additional +6" Range (only for ranged weapons)
- Additional +1 Strength
- Additional -1 AP
- Additional +1 AT
Every enhancement is unique per army. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Simulacrum Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="966d-bfde-c735-4eda">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit receives a +1 bonus to the combat results and can benefit from a maximum of two Acts of Faith at the same time.</characteristic>
            </characteristics>
        </profile>
        <profile name="Storm shield" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="cc5e-9bdb-c532-4a26">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the abilities "Deflect" and "Parry".</characteristic>
            </characteristics>
        </profile>
        <profile name="Swordsman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="dcf7-f413-343a-4c94">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +1 Weapon skill.</characteristic>
            </characteristics>
        </profile>
        <profile name="Teleport homing beacon" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="2a77-620f-0902-4b21">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">A friendly unit arriving within 3" of the bearer via Deep strike does not scatter. The Teleport homer must be present on the table at the beginning of the battle round in order to be used.</characteristic>
            </characteristics>
        </profile>
        <profile name="Trophy" typeId="equipment_type_id" typeName="Equipment" hidden="false" id="dde9-75e9-e202-487a">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the ability "Terrifying(-1)".</characteristic>
            </characteristics>
        </profile>
