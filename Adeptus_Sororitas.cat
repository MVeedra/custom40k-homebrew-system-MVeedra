    <sharedRules>
        <rule name="Acts of Faith" id="1567-2845-ec82-48c9" hidden="false">
            <description>The unit may perform an Act of Faith. Each unit can use as many Acts of Faith per battle round as the army has Faith points, but can only benefit from one effect at a time. Attached character models gain the same benefit, if they have this rule. Even though character models are treated as their own unit in close combat, they benefit from the Act of Faith of the other participating unit.</description>
        </rule>
        <rule name="Pious" id="4f22-a642-cfff-495b" hidden="false">
            <description>The unit generates the specified number of Faith Points for the army.</description>
        </rule>
        <rule name="Shield of Faith" id="0f20-ad41-fb62-409f" hidden="false">
            <description>The model receives a 6+ invulnerability save.</description>
        </rule>
        <rule name="Witch hunters" id="2b9b-c602-910a-4601" hidden="false">
            <description>The army has access to Inquisition units. Inquisitors must select "Ordo Hereticus" in the Armory. The army has access to assassins.</description>
        </rule>
    </sharedRules>
