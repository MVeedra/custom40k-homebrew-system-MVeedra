        <profile name="Combined Conviction" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="97ef-4efe-928b-412f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The army must select a second Legacy. Each model may only select items from one Legacy armory.</characteristic>
            </characteristics>
        </profile>
        <profile name="Deeds, not Words" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="15f9-153b-c3a2-4567">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit may treat all of its "Rapid Fire" weapons during its Activation as "Assault" weapons (f.e. Rapid Fire 1 becomes Assault 1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Devout Fanaticism" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="6061-1a08-6384-48c1">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, it gains +1 to melee hit rolls until the end of the current battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Guided by the Emperor’s Will" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="b76f-b4e9-5e37-4f40">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can re-roll one armor penetration or wound roll per activation.</characteristic>
            </characteristics>
        </profile>
        <profile name="Holy Wrath" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="b6f0-3256-6887-4826">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit uses a Charge order or gets charged by an enemy unit, it gains +1 Strength until the end of the current battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="Raging Fervour" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="26f5-6ca0-f25a-4938">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Inferno pistols gain 1,5" range, Meltas gain 3" range and Multi-melta gain 6" range.</characteristic>
            </characteristics>
        </profile>
        <profile name="Rites of Fire" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="584d-15b9-0cee-47fa">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Hand flamers gain 1,5" range, Flamers gain 3" range and Heavy flamers gain 6" range.</characteristic>
            </characteristics>
        </profile>
        <profile name="Shield of Aversion" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="0f8e-2ba8-bd4a-4a34">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit can reroll one armor save per battle round.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Blood of Martyrs" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="baec-cf50-994f-4454">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit is destroyed, it generates an additional Faith Point.</characteristic>
            </characteristics>
        </profile>
        <profile name="The Emperor's Judgement" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="a7b5-705a-e1db-40fd">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit performs an Act of Faith, roll 1D6. On a 5+, the Faith Point is refunded.        </characteristic>
            </characteristics>
        </profile>
        <profile name="Unbridled Valour" typeId="766f-e609-4aa9-47e8" typeName="Traits" hidden="false" id="8e20-f9ac-30aa-4a69">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains +1 Leadership.</characteristic>
            </characteristics>
        </profile>
        <profile name="Unshakable Vengeance" typeId="equipment_type_id" typeName="Traits" hidden="false" id="07c7-c162-5a40-47de">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The unit gains the "Deflagrate(5+)" ability with Bolt weapons. Does not apply to "Heavy" weapons.</characteristic>
            </characteristics>
        </profile>
