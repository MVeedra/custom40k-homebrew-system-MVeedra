        <entryLink import="true" name="Rhino" hidden="false" id="f13a-0894-9619-4de6" type="selectionEntry" targetId="a503-a1d0-7766-4904">
            <categoryLinks>
                <categoryLink name="Transports" hidden="false" id="91df-52aa-0a37-4970" targetId="8046-e26a-aa36-3308" primary="true"/>
            </categoryLinks>
        </entryLink>
    </entryLinks>
    <sharedRules>
        <rule name="Acts of Faith" id="1567-2845-ec82-48c9" hidden="false">
            <description>The unit may perform an Act of Faith. Each unit can use as many Acts of Faith per battle round as the army has Faith points, but can only benefit from one effect at a time. Attached character models gain the same benefit, if they have this rule. Even though character models are treated as their own unit in close combat, they benefit from the Act of Faith of the other participating unit.</description>
        </rule>
        <rule name="Pious" id="4f22-a642-cfff-495b" hidden="false">
            <description>The unit generates the specified number of Faith Points for the army.</description>
        </rule>
        <rule name="Shield of Faith" id="0f20-ad41-fb62-409f" hidden="false">
            <description>The model receives a 6+ invulnerability save.</description>
        </rule>
        <rule name="Witch hunters" id="2b9b-c602-910a-4601" hidden="false">
            <description>The army has access to Inquisition units. Inquisitors must select "Ordo Hereticus" in the Armory. The army has access to assassins.</description>
        </rule>
        <rule name="Paragon bodyguard" id="4823-326d-409f-4ed6" hidden="false">
            <description>The Canoness may join a unit of Paragon Warsuits.</description>
        </rule>
        <rule name="Pious" id="5fab-f0f3-4365-45e6" hidden="false">
            <description>A Veteran Superior increases the Faith Points by +1.</description>
        </rule>
        <rule name="Faithful" id="1000-8ad3-5d76-48bb" hidden="false">
            <description>Can recite 1 hymn per battle round. A hymn is successfully recited on a roll of 3+. Knows one Hymn of Battle.</description>
        </rule>
        <rule name="Rosarius" id="d3a6-72cf-8f05-45c8" hidden="false">
            <description>This model has a 4+ invulnerability save.</description>
        </rule>
        <rule name="Armour of Saint Catherine" id="fe5a-6b13-2ccd-44e8" hidden="false">
            <description>This model has a 4+ invulnerability save.</description>
        </rule>
        <rule name="Miraculous Intervention" id="9291-6cf3-6180-4bf3" hidden="false">
            <description>Once per battle, after this model has been destroyed, you may spend X Faith Points to return it to the battlefield with X Wounds remaining (to a maximum of 3). Place it as close as possible to the location where it lost its last Wound, but not in base contact with any enemy model.</description>
        </rule>
        <rule name="In training" id="66d3-9d0d-799e-4ddb" hidden="false">
            <description>The army can't have more units of Sister Novitiates than it has Battle Sisters squads.</description>
        </rule>
        <rule name="Concession" id="cf08-f75f-4cdd-4e4c" hidden="false">
            <description>One unit of Crusaders can be selected for each Preacher that does not occupy an Elite slot.</description>
        </rule>
        <rule name="Crusade" id="fdd3-9069-80a1-46cc" hidden="false">
            <description>The model and its attached unit gain the "Frenzy(1")" ability and roll 2D6 (pick highest) for the extra movement with an Advance order.</description>
        </rule>
        <rule name="Advisor" id="400a-74e8-a20d-4b3e" hidden="false">
            <description>For every HQ selection, one Imagifier may be selected without taking up an Elite slot.</description>
        </rule>
        <rule name="Unwavering Resolve" id="e386-7d30-e20f-4281" hidden="false">
            <description>The Dogmata and an attached unit get a 5+ invulnerability saving throw as long as she is within 3" of a mission objective. Does not work against weapons with a Strength of 8 or higher.</description>
        </rule>
        <rule name="Narthecium" id="bffa-50c8-09de-47b4" hidden="false">
            <description>Once per turn, the damage of a wound against the model or attached unit can be reduced by 1. The ability must be declared after armor and invulnerability saves. Does not work against weapons with a strength of 8 or above.</description>
        </rule>
        <rule name="Litany of Glorious Deeds" id="994d-cd21-1d59-4f97" hidden="false">
            <description>At the start of each activation, the Imagifier may choose a legend for themselves and an attached unit
1. Legend of the Devout - The unit gains +1 Movement.
2. Legend of the Defiant - The unit gains +1 Toughness.
3. Legend of the Warriors - The unit gains +1 Strength.
The effect lasts until the Imagifier's next activation.</description>
        </rule>
        <rule name="Shield of Faith" id="9884-6b31-b990-4f3e" hidden="false">
            <description>The Repentia Superior has a 6+ invulnerability save.</description>
        </rule>
        <rule name="Angelic visage" id="cef7-a185-812b-4e77" hidden="false">
            <description>The model gains a 5+ invulnerability save.</description>
        </rule>
        <rule name="Transport" id="02d1-9e4a-7267-467e" hidden="false">
            <description>This model has a transport capacity of 10 infantry models, excluding excluding "Massive(x)" models.</description>
        </rule>
    </sharedRules>
    <sharedSelectionEntryGroups>
    </sharedSelectionEntryGroups>
