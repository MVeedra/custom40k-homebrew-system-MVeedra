            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The models generates +1 Faith Point for the army.</characteristic>
            </characteristics>
        </profile>
        <profile name="Aquila Imperialis" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b37e-5d3b-dad7-4608">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">Instead of rolling for it, the model and the attached unit can automatically pass a Leadership test once per game. Unique</characteristic>
            </characteristics>
        </profile>
        <profile name="Armorium cherub" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="10d3-1978-3ef3-422f">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model or the attached unit can fire a weapon twice during one activation. Each unit can benefit from this effect only once per round. Ammo(1).</characteristic>
            </characteristics>
        </profile>
        <profile name="Auspex scanner" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="478d-93b5-9e5b-4bf4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">If the unit has not already activated this turn, it may immediately use up its order and fire at an enemy unit within 18" that is deployed as reinforcement as if it had been given the "Stand & Shoot" order. The attack resolves after the enemy unit has been deployed and before it takes another action.                                                                                        </characteristic>
            </characteristics>
        </profile>
        <profile name="Blessed ammunition" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="0f41-a9c8-2448-4008">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">One bolt weapon of the model ignores cover. Must be purchased separately for each bolt weapon.</characteristic>
            </characteristics>
        </profile>
        <profile name="Blessing" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="f721-bb57-6dfe-4e53">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model knows one additional Hymn of Battle. Can be taken multiple times.</characteristic>
            </characteristics>
        </profile>
        <profile name="Book of St. Lucius" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="b691-41f5-a890-45d4">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">All friendly units within 6" always use their unmodified Leadership value for tests. Unique.</characteristic>
            </characteristics>
        </profile>
        <profile name="Digital weapons" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="8402-8368-65de-4ff8">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model can make one additional melee attack per round. S:2 AP:-4 D:1. Hits automatically wound.</characteristic>
            </characteristics>
        </profile>
        <profile name="Dominion" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="a131-6ed2-6e56-4939">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains the "Vanguard" ability. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Jump pack" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="40a2-8813-f362-4d71">
            <characteristics>
                <characteristic name="Keywords" typeId="0207-88db-7926-4ba6">The model gains +6" movement and the "Jump pack" rule. Only for infantry.</characteristic>
            </characteristics>
        </profile>
        <profile name="Marksman honours" typeId="03e4-280e-70a0-4395" typeName="Equipment" hidden="false" id="5c60-c125-bd60-48de">
            <characteristics>
